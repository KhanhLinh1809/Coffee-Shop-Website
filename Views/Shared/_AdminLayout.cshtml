<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Cà Phê</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --bg-sidebar: #2A1C14; 
            --bg-surface: #FFFFFF;
            --bg-body: #F4F0EB;
            --border-color: #E2E8F0;
            --text-main: #2D3748;
            --text-muted: #718096;
            --primary-color: #8B5A2B; 
        }

        html { height: 100%; overflow: hidden !important; }
        
        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0; padding: 0; display: flex; 
            height: 100%; 
            overflow: hidden !important;
        }

        /* KHẮC PHỤC TRIỆT ĐỂ LỖI FONT TIẾNG VIỆT TOÀN TRANG */
        h1, h2, h3, h4, h5, h6, span, p, a, div, input, button, textarea, label {
            font-family: 'Be Vietnam Pro', sans-serif !important;
        }

        /* Ngoại trừ các i tag là icon của FontAwesome */
        i.fa-solid, i.fa-brands, i.fa-regular, i.fa {
            font-family: "Font Awesome 6 Free", "Font Awesome 6 Brands" !important;
            font-weight: 900; 
        }

        /* ===== SIDEBAR ===== */
        .sidebar { 
            width: 240px; 
            background-color: var(--bg-sidebar); 
            display: flex; 
            flex-direction: column; 
            transition: 0.3s; 
            z-index: 10; 
        }

        .sidebar-logo {
            padding: 20px 18px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            min-height: 80px; 
            display: flex;
            align-items: center;
            gap: 12px;
            background-color: var(--bg-sidebar);
        }

        .sidebar-logo .logo-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: linear-gradient(135deg, #D4A373 0%, #A0522D 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .sidebar-logo .logo-icon i {
            font-size: 18px;
            color: #FFF;
        }

        .sidebar-logo .logo-text {
            display: flex;
            flex-direction: column;
        }

        .sidebar-logo .logo-text .brand-name {
            font-size: 16px;
            font-weight: 800;
            color: #FFFFFF;
            letter-spacing: 0.5px;
            line-height: 1.2;
        }

        .sidebar-logo .logo-text .brand-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.45);
            font-weight: 500;
            letter-spacing: 0.3px;
        }

        .sidebar-menu { flex: 1; padding: 12px 10px; overflow-y: auto; }

        .menu-item { 
            display: flex; 
            align-items: center; 
            padding: 12px 16px; 
            color: rgba(255,255,255,0.55); 
            text-decoration: none; 
            font-size: 14px; 
            font-weight: 500; 
            gap: 12px; 
            transition: all 0.2s;
            border-radius: 10px;
            margin-bottom: 2px;
        }
        .menu-item i { width: 20px; text-align: center; font-size: 15px; }
        .menu-item:hover { 
            color: #FFF; 
            background: rgba(255,255,255,0.06); 
        }
        .menu-item.active { 
            color: #FFF; 
            background: linear-gradient(135deg, #C68B4E 0%, #A0522D 100%);
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(166, 99, 44, 0.3);
        }

        .sidebar-footer { padding: 16px 10px; border-top: 1px solid rgba(255,255,255,0.05); }
        .btn-logout {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            padding: 11px; border: none; border-radius: 10px;
            background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
            color: #FFF; text-decoration: none; font-weight: 600; font-size: 14px;
            transition: 0.3s; width: 100%;
            box-shadow: 0 3px 10px rgba(231, 76, 60, 0.25);
        }
        .btn-logout:hover { 
            background: linear-gradient(135deg, #C0392B 0%, #A93226 100%); 
            color: #FFF; 
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.35);
        }

        /* ===== MAIN CONTENT ===== */
        .main-wrapper { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; min-width: 0; }
        
        .topbar { 
            height: 65px; 
            background: var(--bg-surface); 
            border-bottom: 1px solid var(--border-color); 
            display: flex; 
            align-items: center; 
            justify-content: flex-end; 
            padding: 0 30px; 
        }
        
        .user-profile { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            font-weight: 600; 
            color: var(--text-main); 
            font-size: 14px; 
        }

        .user-profile span {
            color: var(--text-muted);
            font-weight: 500;
        }

        .user-profile span strong {
            color: var(--text-main);
            font-weight: 700;
        }

        .user-avatar { 
            width: 40px; 
            height: 40px; 
            background: linear-gradient(135deg, #D4A373 0%, #A0522D 100%);
            color: #fff; 
            border-radius: 50%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 16px;
            box-shadow: 0 2px 8px rgba(139, 90, 43, 0.25);
            cursor: pointer;
            transition: 0.3s;
        }
        
        .user-avatar:hover {
            transform: scale(1.1);
        }

        .content-body { 
            flex: 1; 
            padding: 28px; 
            overflow-y: auto; 
            overflow-x: hidden;
            min-height: 0;
            min-width: 0;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #CBD5E0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #A0AEC0; }
    </style>
</head>
<body>
    
    <div class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">
                <i class="fa-solid fa-mug-hot"></i>
            </div>
            <div class="logo-text">
                <span class="brand-name">BREAD&BREW</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>
        
        @{ var currentAction = ViewContext.RouteData.Values["Action"]?.ToString(); }

        <div class="sidebar-menu">
            <a href="/Home/Index" class="menu-item"><i class="fa-solid fa-house"></i> Xem website</a>
            <a href="@Url.Action("User", "Admin")" class="menu-item @(currentAction == "User" ? "active" : "")"><i class="fa-solid fa-users"></i> Quản lý Người dùng</a>
            <a href="@Url.Action("Category", "Admin")" class="menu-item @(currentAction == "Category" ? "active" : "")"><i class="fa-solid fa-tags"></i> Quản lý Danh mục</a>
            <a href="@Url.Action("Menu", "Admin")" class="menu-item @(currentAction == "Menu" ? "active" : "")"><i class="fa-solid fa-book-open"></i> Quản lý Thực đơn</a>
            <a href="@Url.Action("Voucher", "Admin")" class="menu-item @(currentAction == "Voucher" ? "active" : "")"><i class="fa-solid fa-ticket"></i> Quản lý Voucher</a>
            <a href="@Url.Action("Order", "Admin")" class="menu-item @(currentAction == "Order" || currentAction == "OrderDetails" ? "active" : "")"><i class="fa-solid fa-clipboard-list"></i> Danh sách Đơn hàng</a>
            <a href="@Url.Action("Report", "Admin")" class="menu-item @(currentAction == "Report" ? "active" : "")"><i class="fa-solid fa-chart-pie"></i> Báo cáo Thống kê</a>
        </div>

        <div class="sidebar-footer">
            <a asp-controller="Account" asp-action="Logout" class="btn-logout">
                <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="user-profile">
                <span>Xin chào, <strong>@(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Admin Quản Trị")</strong></span>
                
                <a asp-controller="Profile" asp-action="Index" title="Xem Trang cá nhân">
                    <div class="user-avatar"><i class="fa-solid fa-user-tie"></i></div>
                </a>
            </div>
        </div>

        <div class="content-body">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
