    <script>
        let cpTimerInterval;

        function openCoffeePromo() {
            Swal.fire({ title: 'Đang mở hộp quà...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
            
            fetch('/Home/CheckPromoAjax')
                .then(res => res.json())
                .then(data => {
                    Swal.close();
                    if (data.success) {
                        document.getElementById('cpVoucherCodeText').innerText = data.voucherCode;
                        document.getElementById('cpStage').classList.remove('revealed');
                        document.getElementById('coffeePromoModal').classList.add('active');
                        startCPTimer(48 * 60 * 60); // Đếm ngược 48h
                    } else {
                        Swal.fire({ icon: 'info', title: 'Thông báo', text: data.message, confirmButtonColor: '#ea580c' });
                    }
                })
                .catch(err => {
                    Swal.close();
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Có lỗi kết nối. Vui lòng thử lại.', confirmButtonColor: '#ea580c' });
                });
        }

        function closeCoffeePromo() {
            document.getElementById('coffeePromoModal').classList.remove('active');
            clearInterval(cpTimerInterval);
        }

        function pourCoffeePromo() {
            var stage = document.getElementById('cpStage');
            if (!stage.classList.contains('revealed')) {
                stage.classList.add('revealed');
            }
        }

        function copyAndUsePromo() {
            var code = document.getElementById('cpVoucherCodeText').innerText;
            navigator.clipboard.writeText(code).then(() => {
                Swal.fire({
                    icon: 'success', title: 'Đã lưu mã!',
                    text: 'Mã ' + code + ' đã được lưu vào bộ nhớ tạm. Bạn có thể dán vào bước Thanh toán.',
                    confirmButtonColor: '#ea580c'
                }).then(() => {
                    closeCoffeePromo();
                    window.location.href = '/Home/Index?categoryId=0';
                });
            });
        }

        function startCPTimer(duration) {
            clearInterval(cpTimerInterval);
            var timer = duration, hours, minutes, seconds;
            var display = document.getElementById('cpTimer');
            
            cpTimerInterval = setInterval(function () {
                hours = parseInt(timer / 3600, 10);
                minutes = parseInt((timer % 3600) / 60, 10);
                seconds = parseInt(timer % 60, 10);

                hours = hours < 10 ? "0" + hours : hours;
                minutes = minutes < 10 ? "0" + minutes : minutes;
                seconds = seconds < 10 ? "0" + seconds : seconds;

                display.textContent = hours + ":" + minutes + ":" + seconds;

                if (--timer < 0) {
                    timer = 0;
                    clearInterval(cpTimerInterval);
                }
            }, 1000);
        }
    </script>

