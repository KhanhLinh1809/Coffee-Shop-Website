@inject ASM.Data.ApplicationDbContext _dbContextForLayout
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bread & Brew</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: #fdf6f0;
            color: #4b2e2e;
            padding-top: 75px; /* Match header height exactly */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        /* KHẮC PHỤC TRIỆT ĐỂ LỖI FONT TIẾNG VIỆT TOÀN TRANG */
        h1, h2, h3, h4, h5, h6, span, p, a, div, input, button, textarea, label {
            font-family: 'Be Vietnam Pro', sans-serif !important;
        }

        /* Ngoại trừ các i tag là icon của FontAwesome */
        i.fa-solid, i.fa-brands, i.fa-regular, i.fa {
            font-family: "Font Awesome 6 Free", "Font Awesome 6 Brands" !important;
            font-weight: 900; 
        }

        main {
            display: block;
            width: 100%;
            margin: 0 !important;
            padding: 0 !important;
        }

        /* ===== NAVBAR ===== */
        .bb-navbar {
            background-color: #3d2b1f; /* Walnut Wood Base */
            background-image: 
                linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)),
                repeating-linear-gradient(90deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 40px),
                linear-gradient(to bottom, rgba(255,255,255,0.1), transparent 50%, rgba(0,0,0,0.2)),
                url('https://www.transparenttextures.com/patterns/wood-pattern.png');
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
            border-bottom: 3px solid #1a0f0a;
            padding: 0 40px;
            height: 75px;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1030;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .bb-brand {
            font-size: 1.35rem; font-weight: 800;
            color: #FEF3C7 !important;
            text-decoration: none; display: flex; align-items: center; gap: 10px;
            white-space: nowrap;
        }

        .bb-nav-center { display: flex; gap: 5px; }

        .bb-nav-link {
            color: #FEF3C7 !important;
            font-weight: 700; font-size: 0.95rem;
            padding: 10px 15px !important;
            transition: 0.3s;
            text-transform: none;
            border-radius: 6px;
            text-decoration: none !important;
            display: flex;
            align-items: center;
            gap: 6px;
            position: relative;
        }

        .bb-nav-link::after {
            content: "";
            position: absolute;
            bottom: 5px;
            left: 50%;
            width: 0;
            height: 2px;
            background-color: #FBBF24;
            transition: all 0.3s ease;
            transform: translateX(-50%);
            border-radius: 10px;
            opacity: 0;
        }

        .bb-nav-link:hover {
            color: #FBBF24 !important;
            background: rgba(255,255,255,0.05);
            transform: translateY(-2px);
        }

        .bb-nav-link:hover::after {
            width: 30px;
            opacity: 1;
        }

        /* ===== THỰC ĐƠN MEGA MENU ====== */
        .menu-dropdown { position: relative; }
        .menu-dropdown-content {
            position: absolute;
            top: 100%;
            left: -200px;
            background: #ffffff;
            min-width: 700px;
            border-radius: 12px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            opacity: 0;
            visibility: hidden;
            transform: translateY(15px);
            transition: all 0.3s ease;
            z-index: 2000;
            padding: 30px 40px;
            border: 1px solid rgba(0,0,0,0.05);
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
        }
        .menu-dropdown:hover .menu-dropdown-content {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .mm-col h4 {
            color: #116A49; /* Tông màu xanh lá kiểu Phúc Long */
            font-weight: 800;
            font-size: 1.05rem;
            margin-bottom: 15px;
            text-transform: uppercase;
        }
        .mm-col h4.amber { color: #d97706; }
        .m-d-item {
            display: block;
            padding: 8px 0;
            color: #4b2e2e;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: 0.2s;
        }
        .m-d-item:hover { color: #d97706; padding-left: 8px; }

        /* ===== LIVE SEARCH BAR (Expandable) ===== */
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: flex-end;
        }

        .search-input {
            width: 0;
            padding: 8px 0;
            opacity: 0;
            border-radius: 20px;
            border: none;
            background-color: transparent;
            color: #3d2b1f;
            font-weight: 700; font-size: 0.85rem;
            outline: none; 
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }

        .search-container.active .search-input {
            width: 240px;
            padding: 8px 15px 8px 40px;
            opacity: 1;
            background-color: #faf7f0;
            border: 1px solid #dcd3c1;
            pointer-events: auto;
        }

        .search-icon {
            position: absolute; 
            right: 0; top: 50%;
            transform: translateY(-50%);
            color: #FEF3C7; font-size: 1.1rem;
            cursor: pointer;
            transition: 0.3s;
            z-index: 11;
        }

        .search-container.active .search-icon {
            left: 14px;
            right: auto;
            color: #8a6d5a;
            font-size: 0.9rem;
        }

        /* Khung kết quả tìm kiếm */
        .search-results {
            position: absolute;
            top: 110%;
            left: 0;
            width: 100%;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            overflow: hidden;
            z-index: 4000;
            display: none; /* Mặc định ẩn */
            max-height: 400px;
            overflow-y: auto;
        }

        .search-results.active {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* SweetAlert2 phải nằm trên cùng so với sidebar giỏ hàng */
        .swal2-container.swal2-shown {
            z-index: 99999 !important;
        }

        .swal2-backdrop-show {
            z-index: 99998 !important;
        }

        .swal2-popup {
            z-index: 99999 !important;
        }

        .search-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            gap: 15px;
            text-decoration: none;
            color: #4b2e2e;
            border-bottom: 1px solid #f3f4f6;
            transition: 0.2s;
        }

        .search-item:hover {
            background-color: #fef3c7;
        }

        .search-item-img {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            object-fit: cover;
        }

        .search-item-info {
            flex: 1;
        }

        .search-item-name {
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 4px;
        }

        .search-item-price {
            color: #d97706;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .search-loading, .search-empty {
            padding: 20px;
            text-align: center;
            color: #6b4f3a;
            font-weight: 600;
        }

        /* ===== ICON ACTIONS (Giỏ hàng, User) ===== */
        .action-btn {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: #faf7f0;
            color: #5d4037;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; font-size: 1rem;
            transition: 0.2s; box-shadow: 0 2px 5px rgba(0,0,0,0.15);
        }

        .action-btn:hover {
            background: #B45309;
            color: #fff;
            transform: translateY(-1px);
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: #fff;
            font-size: 0.7rem;
            font-weight: 800;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #fff;
        }
        /* ===== USER DROPDOWN ===== */
        .user-dropdown-container {
            position: relative;
            display: flex;
            align-items: center;
        }

        .user-dropdown-menu {
            position: absolute;
            top: 55px;
            right: 0;
            background: #ffffff;
            min-width: 220px;
            border-radius: 16px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
            display: none;
            z-index: 2000;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.05);
            animation: dropdownFade 0.3s ease-out;
        }

        .user-dropdown-menu.active {
            display: block;
        }

        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user-dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 20px;
            text-decoration: none;
            color: #4b2e2e;
            font-weight: 700;
            font-size: 0.95rem;
            transition: 0.2s;
        }

        .user-dropdown-item:hover {
            background-color: #fef3c7;
            color: #d97706;
            padding-left: 25px;
        }

        .user-dropdown-divider {
            height: 1px;
            background-color: #f3f4f6;
            margin: 5px 0;
        }

        .user-dropdown-item.logout {
            color: #ef4444;
        }

        .user-dropdown-item.logout:hover {
            background-color: #fef2f2;
            color: #dc2626;
        }
        /* ===== FOOTER ===== */
        .bb-footer {
            background: #23150D;
            color: #e5e7eb;
            padding: 80px 0 40px;
            width: 100%;
            margin-top: auto;
        }
        .footer-grid {
            max-width: 1200px; margin: 0 auto;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 50px; padding: 0 20px;
        }
        .footer-col h4 { color: #EA580C; font-weight: 800; margin-bottom: 25px; font-size: 1.1rem; text-transform: uppercase; }
        .footer-col p { font-size: 0.95rem; line-height: 1.8; color: #9ca3af; }
        .footer-links { list-style: none; padding: 0; }
        .footer-links li { margin-bottom: 12px; }
        .footer-links a { text-decoration: none; color: #9ca3af; transition: 0.3s; }
        .footer-links a:hover { color: #EA580C; padding-left: 5px; }
        .social-icons { display: flex; gap: 15px; margin-top: 20px; }
        .social-btn { width: 35px; height: 35px; background: #2c1a0e; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: 0.3s; text-decoration: none; }
        .social-btn:hover { background: #EA580C; }

        /* ===== GIỎ HÀNG (SIDEBAR) ===== */
        #overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); display: none; z-index: 1500; }
        #overlay.active { display: block; }

        .cart-sidebar {
            position: fixed; top: 0; right: -420px; width: 400px; height: 100vh;
            background: #fff; z-index: 3000; display: flex; flex-direction: column;
            transition: right 0.5s cubic-bezier(0.25, 1, 0.5, 1);
            box-shadow: -15px 0 40px rgba(0,0,0,0.2);
            color: #4b2e2e;
        }
        .cart-sidebar.active { right: 0; }

        .cart-header {
            padding: 20px 25px; background: #4b2e2e; color: #fef3c7;
            display: flex; justify-content: space-between; align-items: center;
        }
        .cart-header h3 { font-size: 1.2rem; margin: 0; font-weight: 800; }
        .close-btn { font-size: 32px; cursor: pointer; line-height: 1; }

        .cart-content { flex: 1; overflow-y: auto; padding: 20px; background: #fdf6f0; }

        .cart-footer { padding: 25px; background: #fff; border-top: 1px solid #f3f4f6; }
        .btn-checkout-final {
            width: 100%; padding: 14px; background: #d97706; color: white; border: none;
            border-radius: 12px; font-weight: 800; cursor: pointer; transition: 0.3s;
        }
        .btn-checkout-final:hover { background: #b45309; transform: translateY(-2px); }

        .voucher-box { display: flex; gap: 10px; margin-bottom: 20px; position: relative; }
        .voucher-box input { flex: 1; padding: 10px 15px; border-radius: 10px; border: 1px solid #fde68a; outline: none; }
        .voucher-box button { background: #4b2e2e; color: white; border: none; padding: 0 15px; border-radius: 10px; font-weight: bold; }
        .voucher-suggestion-list {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            right: 0;
            background: #ffffff;
            border: 1px solid #fde68a;
            border-radius: 16px;
            box-shadow: 0 18px 40px rgba(0,0,0,0.12);
            z-index: 3500;
            max-height: 260px;
            overflow-y: auto;
        }
        .voucher-suggestion-item {
            padding: 12px 14px;
            cursor: pointer;
            transition: background 0.2s ease;
        }
        .voucher-suggestion-item:hover {
            background: #fffbeb;
        }
        .voucher-suggestion-title {
            font-weight: 800;
            color: #4b2e2e;
        }
        .voucher-suggestion-desc {
            font-size: 0.86rem;
            color: #6b7280;
            margin-top: 4px;
        }
        .voucher-suggestion-empty {
            padding: 14px;
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div id="overlay" onclick="toggleCart()"></div>

    <nav class="bb-navbar">
        
        <!-- TRÁI: LOGO -->
        <a class="bb-brand" href="/Home/Index">
            <img src="~/Images/logo1.png" alt="Bread & Brew Logo" style="height: 50px; width: auto; object-fit: contain;">
        </a>

        <!-- GIỮA: MENU -->
        <div class="bb-nav-center d-none d-xl-flex" style="gap: 30px;">
            <a class="bb-nav-link" href="/Home/Index">Trang chủ</a>
            
            <div class="menu-dropdown">
                <a class="bb-nav-link" href="/Home/Index?categoryId=0">Thực đơn<i class="fa-solid fa-chevron-down" style="font-size: 0.7rem; margin-top: 2px;"></i></a>
                @{
                    var layoutCats = _dbContextForLayout.Categories.Where(c => c.Status == "Active").ToList();
                    
                    int GetCatId(string name) {
                        return layoutCats.FirstOrDefault(c => c.CategoryName.Contains(name))?.CategoryId ?? 0;
                    }
                }
                <div class="menu-dropdown-content">
                    <div class="mm-col">
                        <h4>THỨC UỐNG</h4>
                        <a href="/Home/Index?categoryId=@GetCatId("Cà phê truyền thống")" class="m-d-item">Cà phê truyền thống</a>
                        <a href="/Home/Index?categoryId=@GetCatId("Trà & Trái cây")" class="m-d-item">Trà & Trái cây</a>
                        <a href="/Home/Index?categoryId=@GetCatId("Đá xay")" class="m-d-item">Đá xay (Freeze)</a>
                        <a href="/Home/Index?categoryId=@GetCatId("Nước ép")" class="m-d-item">Nước ép & Sinh tố</a>
                    </div>
                    <div class="mm-col">
                        <h4>BÁNH CÁC LOẠI</h4>
                        <a href="/Home/Index?categoryId=@GetCatId("Bánh ngọt")" class="m-d-item">Bánh ngọt & Pastry</a>
                        <a href="/Home/Index?categoryId=@GetCatId("Bánh mì")" class="m-d-item">Bánh mì & Đồ mặn</a>
                    </div>
                    <div class="mm-col">
                        <h4>SẢN PHẨM KHÁC</h4>
                        <a href="/Home/Index?categoryId=@GetCatId("Cà phê đóng gói")" class="m-d-item">Cà phê đóng gói</a>
                        <a href="/Home/Index?categoryId=@GetCatId("Merchandise")" class="m-d-item">Quà tặng & Phụ kiện</a>
                    </div>
                    <div class="mm-col">
                        <h4 class="amber">XEM TẤT CẢ</h4>
                        <a href="/Home/Index?categoryId=0" class="m-d-item" style="font-weight: 800; color: #d97706;">
                            Toàn bộ Thực đơn <i class="fa-solid fa-arrow-right-long" style="margin-left: 5px;"></i>
                        </a>
                    </div>
                </div>
            </div>

            <a class="bb-nav-link" href="/Home/Voucher">Voucher</a>

            <a class="bb-nav-link" href="/Home/AboutUs">Về chúng tôi</a>
            <!-- <a class="bb-nav-link" href="#" onclick="openCoffeePromo(); return false;" style="position: relative;">
                Khuyến mãi
                <span style="position: absolute; top: -12px; right: -18px; background: #EA580C; color: white; font-size: 0.6rem; padding: 2px 6px; border-radius: 10px; font-weight: 800; border: 2px solid #3d2b1f;">HOT</span>
            </a> -->
        </div>

        <!-- PHẢI: ACTIONS -->
        <div class="d-flex align-items-center gap-3">
            <div class="search-container d-none d-lg-block" id="searchContainer">
                <i class="fa-solid fa-magnifying-glass search-icon" id="toggleSearch"></i>
                <input type="text" id="liveSearchInput" class="search-input" placeholder="Tìm món ăn...">
                <div id="searchResults" class="search-results"></div>
            </div>

            <div class="d-flex gap-2">
                <a href="javascript:void(0)" onclick="toggleCart()" class="action-btn" style="position:relative;">
                    <i class="fa-solid fa-bag-shopping"></i>
                    <span class="cart-badge">0</span>
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <div class="user-dropdown-container">
                        <a href="javascript:void(0)" class="action-btn" id="userMenuBtn"><i class="fa-solid fa-user"></i></a>
                        <div class="user-dropdown-menu" id="userDropdown">
                            <a href="/Profile/Index" class="user-dropdown-item"><i class="fa-solid fa-circle-user" style="color:#d97706;"></i> Hồ sơ</a>
                            <a href="/Order/Index" class="user-dropdown-item"><i class="fa-solid fa-box-open" style="color:#d97706;"></i> Đơn hàng</a>
                            <a href="/Home/MyVoucher" class="user-dropdown-item"><i class="fa-solid fa-ticket" style="color:#d97706;"></i> Kho voucher</a>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="user-dropdown-divider"></div>
                                <a href="/Admin/Report" class="user-dropdown-item" style="color:#d97706;"><i class="fa-solid fa-gauge"></i> Quản trị hệ thống</a>
                            }
                            else if (User.IsInRole("Staff"))
                            {
                                <div class="user-dropdown-divider"></div>
                                <a href="/Staff/OnlineOrder" class="user-dropdown-item" style="color:#d97706;"><i class="fa-solid fa-shop"></i> Quản lý bán hàng</a>
                            }

                            <div class="user-dropdown-divider"></div>
                            <a href="/Account/Logout" class="user-dropdown-item logout"><i class="fa-solid fa-right-from-bracket"></i> Đăng xuất</a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="action-btn"><i class="fa-solid fa-user"></i></a>
                }
            </div>
        </div>
    </nav>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h3><i class="fa-solid fa-cart-shopping"></i> GIỎ HÀNG</h3>
            <span class="close-btn" onclick="toggleCart()">&times;</span>
        </div>
        <div class="cart-content" id="cartList"></div>
        <div class="cart-footer">
            <div style="display:flex; justify-content:space-between; margin-bottom:15px; font-weight:800; font-size:1.1rem;">
                <span>TỔNG TIỀN:</span>
                <span id="cartTotal" style="color:#d97706;">0đ</span>
            </div>
            <div class="voucher-box">
                <input type="text" id="voucherCode" placeholder="Mã giảm giá..." autocomplete="off">
                <button onclick="applyVoucher()">ÁP DỤNG</button>
                <div id="voucherSuggestionList" class="voucher-suggestion-list"></div>
            </div>
            <div id="voucherMessage"></div>
            <button class="btn-checkout-final" onclick="checkout()">THANH TOÁN NGAY</button>
        </div>
    </div>

    <footer class="bb-footer">
        <div class="footer-grid">
            <div class="footer-col">
                <h4 style="color: #fff; font-size: 1.4rem; margin-bottom: 10px;">BREAD & BREW</h4>
                <p>Hương vị cà phê nguyên bản kết hợp cùng bánh ngọt thủ công mang đến trải nghiệm tuyệt vời.</p>
                <div class="social-icons">
                    <a href="#" class="social-btn"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" class="social-btn"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="social-btn"><i class="fa-brands fa-tiktok"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h4>Sản Phẩm</h4>
                <ul class="footer-links">
                    <li><a href="/Home/Index?categoryId=1">Cà Phê Truyền Thống</a></li>
                    <li><a href="/Home/Index?categoryId=2">Trà & Đá Xay</a></li>
                    <li><a href="/Home/Index?categoryId=3">Bánh Ngọt Thủ Công</a></li>
                    <li><a href="/Home/Index?categoryId=4">Quà Tặng Coffee</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Liên Hệ</h4>
                <ul class="footer-links" style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 12px;"><i class="fa-solid fa-phone me-2" style="color: #EA580C;"></i> 1900 1508</li>
