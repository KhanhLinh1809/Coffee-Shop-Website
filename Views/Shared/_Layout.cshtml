                .catch(() => {}); // Không hiện lỗi nếu API fail
        });

        function openGiftOverlay() {
            var overlay = document.getElementById('giftOverlay');
            overlay.style.display = 'flex';
            document.body.style.overflow = 'hidden';

            // Reset về scene 1 khi mở lại
            document.getElementById('giftScene').style.display = 'block';
            document.getElementById('giftVoucherCard').style.display = 'none';
        }

        function closeGiftOverlay() {
            document.getElementById('giftOverlay').style.display = 'none';
            document.body.style.overflow = '';
