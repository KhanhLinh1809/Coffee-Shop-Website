                // Hiển thị trạng thái đã lưu nếu cần
                if (_giftData && _giftData.alreadySaved) {
                    var actionArea = document.getElementById('giftActionArea');
                    actionArea.innerHTML = '<div style="text-align:center; padding:10px;"><i class="fa-solid fa-circle-check" style="color:#10b981; font-size:2rem;"></i><p style="font-weight:900; color:#065f46; margin-top:8px;">Đã lưu vào Kho Voucher! 🎉</p><p style="font-size:0.8rem; color:#6b7280;">Sử dụng khi đặt hàng để được giảm 90%</p></div>';
                }
            }, 350);
        }

        function spawnParticles() {
            var emojis = ['🎉', '🎊', '⭐', '✨', '🌟', '💫', '🎁', '🎈'];
            for (var i = 0; i < 18; i++) {
                (function(idx) {
                    setTimeout(() => {
                        var p = document.createElement('div');
                        p.className = 'gift-particle';
                        p.innerText = emojis[Math.floor(Math.random() * emojis.length)];
                        var startX = window.innerWidth / 2 + (Math.random() - 0.5) * 100;
                        var startY = window.innerHeight / 2 + (Math.random() - 0.5) * 100;
                        p.style.left = startX + 'px';
                        p.style.top = startY + 'px';
                        var angle = Math.random() * 360;
                        var dist = 120 + Math.random() * 200;
                        p.style.setProperty('--px', (Math.cos(angle) * dist) + 'px');
                        p.style.setProperty('--py', (Math.sin(angle) * dist) + 'px');
                        document.body.appendChild(p);
                        setTimeout(() => p.remove(), 1300);
                    }, idx * 50);
                })(i);
            }
        }

        function startCountdown(expiryTimestamp) {
            if (_giftCountdownInterval) clearInterval(_giftCountdownInterval);
            _giftCountdownInterval = setInterval(() => {
                var now = Math.floor(Date.now() / 1000);
                var remaining = expiryTimestamp - now;
                if (remaining <= 0) {
                    clearInterval(_giftCountdownInterval);
                    document.getElementById('giftCountdown').innerText = 'HẾT HẠN';
                    document.getElementById('giftCountdown').style.color = '#ef4444';
                    document.getElementById('giftBoxBtn').style.display = 'none';
                    return;
                }
                var h = Math.floor(remaining / 3600);
                var m = Math.floor((remaining % 3600) / 60);
                var s = remaining % 60;
                var fmt = (n) => n < 10 ? '0' + n : '' + n;
                document.getElementById('giftCountdown').innerText = fmt(h) + ':' + fmt(m) + ':' + fmt(s);
            }, 1000);
        }

        function saveGiftVoucher() {
            if (!_giftData) return;
            var btn = document.getElementById('btnSaveGift');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';
            btn.style.pointerEvents = 'none';

            fetch('/Home/SaveVoucherToDb?voucherId=' + _giftData.voucherId, {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => {
                if (!res.ok) throw new Error('Server error: ' + res.status);
                return res.json();
            })
            .then(data => {
                if (data.success) {
                    _giftData.alreadySaved = true;
                    document.getElementById('giftActionArea').innerHTML = `
                        <div style="text-align:center; padding:10px 0;">
                            <div style="font-size:3rem; margin-bottom:8px;">🎉</div>
                            <div style="font-weight:900; color:#065f46; font-size:1.1rem;">Đã lưu vào Kho Voucher!</div>
                            <div style="font-size:0.8rem; color:#6b7280; margin-top:4px;">Dùng khi đặt hàng để được giảm 90%</div>
                            <a href="/Home/MyVoucher" style="display:inline-block; margin-top:14px; padding:10px 24px; background:linear-gradient(90deg,#ea580c,#d97706); color:#fff; border-radius:10px; font-weight:900; text-decoration:none; font-size:0.9rem;">Xem Kho Voucher</a>
                        </div>`;
                    document.querySelector('#giftBoxBtn .gift-badge').style.display = 'none';
                } else {
                    alert(data.message || 'Lỗi không xác định');
                    btn.innerHTML = '🎁 LƯU LẠI';
                    btn.style.pointerEvents = 'auto';
                }
            })
            .catch(err => {
                console.error(err);
                btn.innerHTML = '❌ Lỗi hệ thống';
                alert('Có lỗi xảy ra: ' + err.message);
                btn.style.pointerEvents = 'auto';
            });
        }
    </script>
    }

</body>
</html>
