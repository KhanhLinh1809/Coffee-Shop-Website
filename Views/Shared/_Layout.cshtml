        function openGiftBox() {
            // Tung confetti
            spawnParticles();

            // Hiệu ứng shake rồi ẩn box
            var box = document.getElementById('giftBox3d');
            box.style.animation = 'none';
            box.style.transform = 'scale(1.2) rotate(10deg)';
            setTimeout(() => { box.style.transform = 'scale(0) rotate(-30deg)'; }, 150);

            setTimeout(() => {
