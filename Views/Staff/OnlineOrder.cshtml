@model IEnumerable<ASM.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn - Trực tuyến";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
    
    // Group orders
    var newOrders = Model.Where(o => o.OrderStatus == 1).ToList();
    var processingOrders = Model.Where(o => o.OrderStatus == 2 || o.OrderStatus == 3).ToList();
    var readyOrders = Model.Where(o => o.OrderStatus >= 4).ToList(); // includes Completed & Cancelled
}

<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: { fontFamily: { sans: ['Inter', 'sans-serif'], } }
        }
    }
</script>

<style>
    /* Xóa padding mặc định của layout */
    .content-body { padding: 0 !important; background-color: #121212; }
    
    /* Custom Scrollbar */
    .custom-scroll::-webkit-scrollbar { width: 5px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 10px; }
    
    /* Active state cho tab và card */
    .oo-tab.active { color: #f59e0b; border-bottom: 2px solid #f59e0b; }
    .oo-card.active { border-color: #f59e0b; background-color: rgba(245, 158, 11, 0.05); }
</style>

<div class="flex h-[calc(100vh-65px)] text-neutral-200 font-sans overflow-hidden">
    
    <div class="w-[420px] bg-gradient-to-b from-neutral-900 to-neutral-950 border-r border-amber-900/30 flex flex-col shadow-2xl flex-shrink-0">
        
        <div class="p-6 pb-0 border-b border-neutral-800">
            <div class="flex items-center gap-3 mb-6">
                <span class="text-amber-500 font-black text-xl tracking-wider">BREAD & BREW</span>
                <span class="text-neutral-500 font-medium border-l border-neutral-600 pl-3">Đơn trực tuyến</span>
            </div>
            
            <div class="flex gap-6">
                <button id="btn-tab-new" class="oo-tab active pb-3 text-sm font-bold text-neutral-400 hover:text-amber-400 transition-colors uppercase tracking-wide" onclick="switchTab('tab-new', this)">
                    MỚI (@newOrders.Count)
                </button>
                <button id="btn-tab-processing" class="oo-tab pb-3 text-sm font-bold text-neutral-400 hover:text-amber-400 transition-colors uppercase tracking-wide" onclick="switchTab('tab-processing', this)">
                    XỬ LÝ (@processingOrders.Count)
                </button>
                <button id="btn-tab-ready" class="oo-tab pb-3 text-sm font-bold text-neutral-400 hover:text-amber-400 transition-colors uppercase tracking-wide" onclick="switchTab('tab-ready', this)">
                    LỊCH SỬ (@readyOrders.Count)
                </button>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto p-5 custom-scroll">
            
            <div id="tab-new" class="tab-content block space-y-3">
                @if(!newOrders.Any()) { 
                    <div class="text-center text-neutral-500 mt-10 font-medium">Không có đơn hàng mới.</div> 
                }
                @foreach(var o in newOrders) { 
                    var timeStr = (DateTime.Now - o.CreatedAt).TotalMinutes < 60 ? $"{(int)(DateTime.Now - o.CreatedAt).TotalMinutes} phút trước" : o.CreatedAt.ToString("HH:mm");
                    var itemCnt = o.OrderDetails?.Sum(x => x.Quantity) ?? 0;
                    var pmStr = o.PaymentMethod == 1 ? "TIỀN MẶT" : "CHUYỂN KHOẢN";

                    <div class="oo-card bg-[#1E1E1E] border border-neutral-700/50 rounded-2xl p-4 cursor-pointer hover:border-neutral-500 transition-all relative" id="card-@o.OrderId" onclick="showOrder(@o.OrderId, this)">
                        <div class="absolute top-4 right-4 bg-blue-900/40 text-blue-400 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider border border-blue-800">
                            Đơn mới
                        </div>
                        <div class="text-xs text-amber-500 font-bold mb-1">#ORD-@o.OrderId.ToString("D4")</div>
                        <div class="text-base font-bold text-white mb-2 truncate pr-20">@(o.User?.FullName ?? "Khách hàng")</div>
                        <div class="text-xs text-neutral-400 flex items-center gap-2">
                            <span><i class="fa-regular fa-clock"></i> @timeStr</span>
                            <span>•</span>
                            <span>@itemCnt món</span>
                            <span>•</span>
                            <span class="text-emerald-500 font-semibold">@pmStr</span>
                        </div>
                    </div>
                }
            </div>

            <div id="tab-processing" class="tab-content hidden space-y-3">
                @if(!processingOrders.Any()) { 
                    <div class="text-center text-neutral-500 mt-10 font-medium">Không có đơn đang xử lý.</div> 
                }
                @foreach(var o in processingOrders) { 
                    var timeStr = (DateTime.Now - o.CreatedAt).TotalMinutes < 60 ? $"{(int)(DateTime.Now - o.CreatedAt).TotalMinutes} phút trước" : o.CreatedAt.ToString("HH:mm");
                    var itemCnt = o.OrderDetails?.Sum(x => x.Quantity) ?? 0;
                    var pmStr = o.PaymentMethod == 1 ? "TIỀN MẶT" : "CHUYỂN KHOẢN";
                    var stLabel = o.OrderStatus == 2 ? "Chuẩn bị" : "Đang giao";
                    var stClass = o.OrderStatus == 2 ? "bg-amber-900/40 text-amber-400 border-amber-800" : "bg-emerald-900/40 text-emerald-400 border-emerald-800";

                    <div class="oo-card bg-[#1E1E1E] border border-neutral-700/50 rounded-2xl p-4 cursor-pointer hover:border-neutral-500 transition-all relative" id="card-@o.OrderId" onclick="showOrder(@o.OrderId, this)">
                        <div class="absolute top-4 right-4 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider border @stClass">
                            @stLabel
                        </div>
                        <div class="text-xs text-amber-500 font-bold mb-1">#ORD-@o.OrderId.ToString("D4")</div>
                        <div class="text-base font-bold text-white mb-2 truncate pr-20">@(o.User?.FullName ?? "Khách hàng")</div>
                        <div class="text-xs text-neutral-400 flex items-center gap-2">
                            <span><i class="fa-regular fa-clock"></i> @timeStr</span>
                            <span>•</span>
                            <span>@itemCnt món</span>
                            <span>•</span>
                            <span class="text-emerald-500 font-semibold">@pmStr</span>
                        </div>
                    </div>
                }
            </div>

            <div id="tab-ready" class="tab-content hidden space-y-3">
                @if(!readyOrders.Any()) { 
                    <div class="text-center text-neutral-500 mt-10 font-medium">Không có lịch sử đơn.</div> 
                }
                @foreach(var o in readyOrders) { 
                    var timeStr = o.CreatedAt.ToString("HH:mm dd/MM");
                    var itemCnt = o.OrderDetails?.Sum(x => x.Quantity) ?? 0;
                    
                    // ĐÃ SỬA: Nếu Hoàn Thành (4) thì chỉ hiện "ĐÃ THANH TOÁN", nếu Hủy thì hiện "ĐÃ HỦY"
                    var pmStr = "";
                    if (o.OrderStatus == 4) pmStr = "ĐÃ THANH TOÁN";
                    else if (o.OrderStatus > 4) pmStr = "ĐÃ HỦY";
                    else pmStr = o.PaymentMethod == 1 ? "TIỀN MẶT" : "CHUYỂN KHOẢN";

                    var pmColor = o.OrderStatus == 4 ? "text-emerald-500" : (o.OrderStatus > 4 ? "text-red-500" : "text-emerald-500");
                    
                    var stLabel = o.OrderStatus == 4 ? "Hoàn thành" : "Đã hủy";
                    var stClass = o.OrderStatus == 4 ? "bg-emerald-900/40 text-emerald-500 border-emerald-800" : "bg-red-900/40 text-red-400 border-red-800";

                    <div class="oo-card bg-[#1E1E1E] border border-neutral-700/50 rounded-2xl p-4 cursor-pointer hover:border-neutral-500 transition-all relative opacity-70 hover:opacity-100" id="card-@o.OrderId" onclick="showOrder(@o.OrderId, this)">
                        <div class="absolute top-4 right-4 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider border @stClass">
                            @stLabel
                        </div>
                        <div class="text-xs text-amber-500 font-bold mb-1">#ORD-@o.OrderId.ToString("D4")</div>
                        <div class="text-base font-bold text-white mb-2 truncate pr-20">@(o.User?.FullName ?? "Khách hàng")</div>
                        <div class="text-xs text-neutral-400 flex items-center gap-2">
                            <span><i class="fa-regular fa-clock"></i> @timeStr</span>
                            <span>•</span>
                            <span>@itemCnt món</span>
                            <span>•</span>
                            <span class="@pmColor font-semibold">@pmStr</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="flex-1 bg-[#121212] relative overflow-hidden flex flex-col">
        
        <div id="empty-detail" class="flex flex-col items-center justify-center h-full text-neutral-600">
            <i class="fa-solid fa-file-invoice text-6xl mb-4 opacity-50"></i>
            <p class="font-medium text-lg">Chọn một đơn hàng để xem chi tiết</p>
        </div>

        @foreach(var o in Model)
        {
            <div id="detail-@o.OrderId" class="detail-panel hidden flex-col h-full overflow-y-auto custom-scroll p-8 items-center">
                
                <div class="w-full max-w-2xl">
                    
                    <div class="flex justify-between items-end mb-6">
                        <div>
                            <h2 class="text-3xl font-black text-white mb-1">ĐƠN #@o.OrderId.ToString("D4")</h2>
                            <p class="text-neutral-400 font-medium">@o.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
                        </div>
                        
                        @{
                            string badgeText = "";
                            string psColor = "";

                            if (o.OrderStatus == 4) 
                            {
                                badgeText = "✓ ĐÃ THANH TOÁN";
                                psColor = "text-emerald-400 border-emerald-500/30 bg-emerald-500/10";
                            }
                            else if (o.OrderStatus > 4) 
                            {
                                badgeText = "✕ ĐÃ HỦY";
                                psColor = "text-red-400 border-red-500/30 bg-red-500/10";
                            }
                            else 
                            {
                                var pmText = o.PaymentMethod == 1 ? "TIỀN MẶT" : "CHUYỂN KHOẢN";
                                var psText = o.PaymentStatus == 1 ? "✓ ĐÃ THANH TOÁN" : "⚠ CHƯA THANH TOÁN";
                                badgeText = pmText + " • " + psText;
                                psColor = o.PaymentStatus == 1 ? "text-emerald-400 border-emerald-500/30 bg-emerald-500/10" : "text-red-400 border-red-500/30 bg-red-500/10";
                            }
                        }
                        
                        <div class="px-4 py-2 rounded-xl border @psColor font-bold text-sm tracking-wide">
                            @badgeText
                        </div>
                    </div>

                    <div class="bg-[#1E1E1E] border border-neutral-700/50 rounded-2xl p-6 mb-6 flex gap-5 items-center shadow-lg">
                        <div class="w-16 h-16 rounded-2xl bg-amber-600 flex items-center justify-center text-white text-2xl font-bold shadow-inner">
                            @(string.IsNullOrEmpty(o.User?.FullName) ? "K" : o.User.FullName.Substring(0,1).ToUpper())
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-white mb-2">@(o.User?.FullName ?? "Khách hàng hệ thống")</h3>
                            <div class="space-y-1">
                                <p class="text-sm text-neutral-400 flex items-center gap-2"><i class="fa-solid fa-phone text-amber-500 w-4"></i> @(o.User?.Phone ?? "Không có SĐT")</p>
                                <p class="text-sm text-neutral-400 flex items-center gap-2"><i class="fa-solid fa-location-dot text-amber-500 w-4"></i> @(o.User?.Address ?? "Nhận tại quán")</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-[#1E1E1E] border border-neutral-700/50 rounded-2xl p-6 mb-6 shadow-lg">
                        <h4 class="text-amber-500 font-bold tracking-wide uppercase mb-4 text-sm">Chi tiết món</h4>
                        
                        <div class="space-y-4">
                            @foreach(var item in o.OrderDetails)
                            {
                                <div class="flex justify-between items-start text-neutral-200">
                                    <div class="flex gap-3">
                                        <span class="font-bold text-amber-400 w-6">@item.Quantity x</span>
                                        <span class="font-medium">@(item.Product?.ProductName ?? "Sản phẩm")</span>
                                    </div>
                                    <span class="font-semibold">@((item.Price * item.Quantity).ToString("N0"))đ</span>
                                </div>
                            }
                        </div>
                        
                        <div class="mt-6 pt-5 border-t border-neutral-700 border-dashed flex justify-between items-center">
                            <span class="text-lg font-bold text-white">Tổng cộng:</span>
                            <span class="text-2xl font-black text-amber-500">@o.FinalAmount.ToString("N0")đ</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(o.Note))
                    {
                        <div class="bg-amber-900/20 border border-amber-500/30 rounded-2xl p-5 mb-6 flex gap-3">
                            <span class="text-amber-500 font-bold text-sm uppercase tracking-wide whitespace-nowrap">Ghi chú:</span>
                            <span class="text-amber-100 text-sm font-medium">@o.Note</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(o.CancelReason))
                    {
                        <div class="bg-red-900/20 border border-red-500/30 rounded-2xl p-5 mb-6 flex gap-3">
                            <span class="text-red-500 font-bold text-sm uppercase tracking-wide whitespace-nowrap">Lý do hủy:</span>
                            <span class="text-red-100 text-sm font-medium">@o.CancelReason</span>
                        </div>
                    }

                    @if (o.OrderStatus < 4)
                    {
                        <div class="flex gap-4 mt-8">
                            @if (o.OrderStatus == 1)
                            {
                                <button type="button" onclick="updateOrderStatus(event, @o.OrderId, 2)" class="flex-1 py-4 rounded-xl bg-amber-600 hover:bg-amber-500 text-white font-bold text-[15px] transition-colors shadow-lg shadow-amber-900/20 flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-fire-burner"></i> TIẾP NHẬN & CHUẨN BỊ
                                </button>
                            }
                            else if (o.OrderStatus == 2)
                            {
                                <button type="button" onclick="updateOrderStatus(event, @o.OrderId, 3)" class="flex-1 py-4 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-[15px] transition-colors shadow-lg shadow-blue-900/20 flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-motorcycle"></i> GIAO HÀNG
                                </button>
                            }
                            else if (o.OrderStatus == 3)
                            {
                                <button type="button" onclick="updateOrderStatus(event, @o.OrderId, 4)" class="flex-1 py-4 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-[15px] transition-colors shadow-lg shadow-emerald-900/20 flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-flag-checkered"></i> XÁC NHẬN HOÀN THÀNH
                                </button>
                            }

                            <button type="button" class="w-[140px] py-4 rounded-xl bg-neutral-800 hover:bg-red-500/20 border border-neutral-700 hover:border-red-500 text-neutral-400 hover:text-red-500 font-bold text-[15px] transition-colors flex items-center justify-center gap-2" onclick="cancelOrderPrompt(@o.OrderId, this)">
                                <i class="fa-solid fa-xmark"></i> HỦY
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            let savedTab = localStorage.getItem("activeOnlineOrderTab");
            if(savedTab) {
                let btn = document.getElementById("btn-" + savedTab);
                if(btn) {
                    switchTab(savedTab, btn);
                }
            }
        });

        function switchTab(tabId, btnEl) {
            document.querySelectorAll('.tab-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block');
            });
            document.querySelectorAll('.oo-tab').forEach(el => el.classList.remove('active'));
            
            document.getElementById(tabId).classList.remove('hidden');
            document.getElementById(tabId).classList.add('block');
            btnEl.classList.add('active');

            localStorage.setItem("activeOnlineOrderTab", tabId);
        }

        function showOrder(id, cardEl) {
            document.querySelectorAll('.oo-card').forEach(c => c.classList.remove('active'));
            cardEl.classList.add('active');

            document.getElementById('empty-detail').classList.add('hidden');
            document.getElementById('empty-detail').classList.remove('flex');

            document.querySelectorAll('.detail-panel').forEach(p => {
                p.classList.add('hidden');
                p.classList.remove('flex');
            });

            let target = document.getElementById('detail-' + id);
            if (target) {
                target.classList.remove('hidden');
                target.classList.add('flex');
            }
        }

        function updateOrderStatus(event, orderId, status) {
            event.preventDefault();
            let btn = event.currentTarget;
            let originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> ĐANG XỬ LÝ...';
            btn.disabled = true;

            let formData = new FormData();
            formData.append('orderId', orderId);
            formData.append('orderStatus', status);

            fetch('/Staff/UpdateOrderStatus', {
                method: 'POST',
                body: formData
            }).then(() => {
                window.location.reload();
            }).catch(err => {
                alert('Lỗi kết nối đến máy chủ!');
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            });
        }

        function cancelOrderPrompt(id, btnEl) {
            let reason = prompt("Vui lòng nhập lý do hủy đơn (Khách bom, không liên lạc được...):");
            if(reason !== null && reason.trim() !== "") {
                
                let originalHtml = btnEl.innerHTML;
                btnEl.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>...';
                btnEl.disabled = true;

                let formData = new FormData();
                formData.append('orderId', id);
                formData.append('cancelReason', reason);

                fetch('/Staff/CancelOrder', {
                    method: 'POST',
                    body: formData
                }).then(() => {
                    window.location.reload();
                }).catch(err => {
                    alert('Lỗi kết nối đến máy chủ!');
                    btnEl.innerHTML = originalHtml;
                    btnEl.disabled = false;
                });
                
            } else if (reason !== null) {
                alert("Lỗi: Lý do hủy đơn không được để trống!");
            }
        }
    </script>
}