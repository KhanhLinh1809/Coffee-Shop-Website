@{
    ViewData["Title"] = "Về chúng tôi - Bread & Brew";
}

<style>
    /* Thêm font chữ serif cao cấp cho tiêu đề */
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap');
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@800;900&display=swap');

    body {
        background-color: #fcf9f6; /* Nền vàng kem cực kỳ nhạt, siêu sang */
    }

    /* ---- BANNER VỚI HIỆU ỨNG PARALLAX ---- */
    .about-banner {
        position: relative;
        width: 100vw;
        left: 50%;
        transform: translateX(-50%);
        height: 480px; 
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(20, 10, 5, 0.5), rgba(20, 10, 5, 0.85)), url('https://images.unsplash.com/photo-1497935586351-b67a49e012bf?q=80&w=1920') center/cover;
        background-attachment: fixed; /* Parallax siêu mượt */
        margin-top: 0;
    }
    
    .about-banner h1 {
        font-family: 'Playfair Display', serif;
        color: #F8FAFC;
        font-size: 4.5rem;
        font-weight: 900;
        letter-spacing: 4px;
        text-shadow: 0 10px 30px rgba(0,0,0,0.8);
        margin: 0;
        position: relative;
        padding-bottom: 15px;
    }
    
    .about-banner h1::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 4px;
        background: #EA580C;
        border-radius: 2px;
    }

    .about-content-section {
        max-width: 1200px;
        margin: 100px auto;
        padding: 0 20px;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    /* ---- KHU VỰC HÌNH ẢNH TRÁI (SÁNG TẠO HƠN) ---- */
    .about-img-wrap {
        position: relative;
        padding-bottom: 40px;
        padding-right: 40px;
    }

    .about-img-bg {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 85%;
        height: 85%;
        background-color: #fef3c7; /* Nền khối hộp lệch */
        border-radius: 30px;
        z-index: 0;
        transition: 0.5s;
    }

    .about-img-wrap:hover .about-img-bg {
        transform: translate(15px, 15px);
        background-color: #fde68a;
    }

    .about-img-box {
        position: relative;
        border-radius: 30px;
        overflow: hidden;
        z-index: 1;
        box-shadow: 0 30px 60px rgba(35, 21, 13, 0.2);
        aspect-ratio: 1/1; 
        border: 12px solid #fff;
    }

    .about-img-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.7s ease;
    }

    .about-img-wrap:hover .about-img-box img {
        transform: scale(1.08) rotate(-2deg);
    }

    /* Icon Badge lơ lửng */
    .premium-badge {
        position: absolute;
        top: 40px;
        left: -30px;
        background: #EA580C;
        color: #fff;
        border-radius: 50%;
        width: 110px;
        height: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-weight: 800;
        line-height: 1.2;
        box-shadow: 0 15px 30px rgba(234, 88, 12, 0.4);
        z-index: 3;
        animation: float 4s ease-in-out infinite;
        border: 5px solid #fff;
    }
    
    .premium-badge span { font-size: 1.5rem; }
    .premium-badge small { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }

    /* ---- KHU VỰC CHỮ PHẢI ---- */
    .about-subtitle {
        color: #EA580C;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 20px;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .about-subtitle::before {
        content: '';
        display: block;
        width: 50px;
        height: 3px;
        background: #EA580C;
    }

    .about-title {
        font-family: 'Playfair Display', serif;
        color: #23150D;
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 30px;
    }

    .about-desc {
        color: #6b4f3a;
        font-size: 1.15rem;
        line-height: 1.9;
        margin-bottom: 40px;
        text-align: justify;
    }

    /* ---- CHỈ SỐ BÊN DƯỚI (PHONG CÁCH TRANSPARENT) ---- */
    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px 30px;
        padding-top: 20px;
    }

    .stat-item {
        text-align: left;
        padding-left: 25px;
        border-left: 4px solid #fde68a;
        transition: 0.4s;
    }

    .stat-item:hover {
        transform: translateX(10px);
        border-left-color: #EA580C;
    }

    .stat-number {
        font-family: 'Montserrat', sans-serif;
        font-size: 4.5rem;
        font-weight: 900;
        margin-bottom: 5px;
        line-height: 1;
        color: #23150D; 
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        letter-spacing: -3px;
    }
    
    .stat-item:hover .stat-number {
        color: #EA580C;
        transform: scale(1.08);
    }
    
    .stat-text {
        color: #23150D;
        font-weight: 700;
        font-size: 1.05rem;
        line-height: 1.5;
    }

    /* Hiệu ứng Odometer từng chữ số độc lập - Cấu trúc siêu bền vững */
    .stat-number { 
        display: flex; 
        align-items: baseline; 
        justify-content: flex-start;
        gap: 0;
    }
    .odometer-container { 
        display: inline-flex; 
        height: 1.3em; 
        overflow: hidden; 
        line-height: 1.3em;
        vertical-align: bottom;
    }
    .digit-col { 
        display: flex; 
        flex-direction: column; 
        transition: transform 0.8s cubic-bezier(0.45, 0.05, 0.55, 0.95); 
        width: 0.7em; /* Cố định chiều rộng cột để không bị nhảy khi đổi số */
    }
    .digit-val { 
        height: 1.3em; 
        line-height: 1.3em; 
        display: block; 
        text-align: center; 
        flex-shrink: 0;
    }
    .stat-sign { font-size: 2.5rem; color: #23150D; align-self: center; margin-left: 5px; }
    
    .digit-col.is-rolling { color: #EA580C; }

    @@media (max-width: 991px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 50px;
        }
        .about-title {
            font-size: 2.8rem;
        }
        .about-banner {
            height: 300px;
        }
        .about-banner h1 {
            font-size: 3rem;
        }
        .premium-badge {
            left: 10px;
        }
    }
</style>

<div class="about-banner">
    <h1>Về chúng tôi</h1>
</div>

<div class="about-content-section">
    <div class="about-grid">
        <!-- Khu vực hình ảnh (Trái) - Thiết kế cao cấp có bóng và badge nổi -->
        <div class="about-img-wrap">
            <div class="about-img-bg"></div>
            <div class="premium-badge">
                <span>100%</span>
                <small>Premium</small>
            </div>
            <div class="about-img-box">
                <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?q=80&w=1000" alt="Bread & Brew Story">
            </div>
        </div>

        <!-- Khu vực nội dung (Phải) -->
        <div class="about-text-box">
            <div class="about-subtitle">Câu chuyện của chúng tôi</div>
            <!-- Tiêu đề lớn dùng font chữ có chân (serif) cực kỳ sang trọng -->
            <h2 class="about-title">Mang đến hương vị trọn vẹn trong từng món</h2>
            <div class="about-desc">
                Bread & Brew là nơi hội tụ của cà phê thơm đậm, trà sữa ngọt dịu và những chiếc bánh ngọt tươi mới mỗi ngày. Chúng tôi chọn lọc nguyên liệu kỹ càng, chú trọng hương vị và trải nghiệm để mỗi lần ghé thăm đều là một khoảnh khắc thư giãn, ấm áp và đáng nhớ.
            </div>

            <!-- Khối 4 chỉ số (Dùng hiệu ứng chữ rỗng viền màu độc đáo) -->
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-number">
                        <span id="count-recipes" class="odometer-container"></span>
                        <span class="stat-sign">+</span>
                    </div>
                    <div class="stat-text">Công thức đồ uống và bánh<br>được hoàn thiện</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">
                        <span id="count-orders" class="odometer-container"></span>
                        <span class="stat-sign">+</span>
                    </div>
                    <div class="stat-text">Đơn hàng<br>đã được phục vụ</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">
                        <span id="count-clients" class="odometer-container"></span>
                        <span class="stat-sign">+</span>
                    </div>
                    <div class="stat-text">Khách hàng<br>cực kỳ hài lòng</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">
                        <span id="count-bestsellers" class="odometer-container"></span>
                    </div>
                    <div class="stat-text">Món bán chạy<br>được yêu thích nhất</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const odometerConfigs = [
        { id: 'count-recipes', start: 0, target: 20 },
        { id: 'count-orders', start: 800, target: 1250 }, 
        { id: 'count-clients', start: 0, target: 300 },
        { id: 'count-bestsellers', start: 0, target: 64 }
    ];

    function initOdometers() {
        odometerConfigs.forEach(conf => {
            const container = document.getElementById(conf.id);
            if (!container) return;
            setupOdometer(container, conf.start);
            
            // Chạy hiệu ứng đếm số lên đỉnh (vượt qua các số trung gian)
            setTimeout(() => {
                animateCountingUp(container, conf.start, conf.target, () => {
                    // Sau khi lên đỉnh xong mới bắt đầu chế độ nhảy số ngẫu nhiên
                    startLiveUpdates(conf.id, conf.target);
                });
            }, 800);
        });
    }

    // Hàm đếm số từ từ lên đỉnh
    function animateCountingUp(container, start, end, callback) {
        let current = start;
        const duration = 2500; // 2.5 giây để chạy lên đỉnh
        const steps = end - start;
        if (steps <= 0) {
            renderOdometer(container, end);
            if (callback) callback();
            return;
        }

        const startTime = performance.now();

        function step(now) {
            const progress = Math.min((now - startTime) / duration, 1);
            const val = Math.floor(progress * (end - start) + start);
            
            renderOdometer(container, val);

            if (progress < 1) {
                requestAnimationFrame(step);
            } else {
                renderOdometer(container, end);
                if (callback) callback();
            }
        }
        requestAnimationFrame(step);
    }

    function setupOdometer(el, value) {
        const str = value.toString();
        el.innerHTML = '';
        for (let char of str) {
            const col = document.createElement('div');
            col.className = 'digit-col';
            for (let i = 0; i <= 9; i++) {
                const val = document.createElement('span');
                val.className = 'digit-val';
                val.textContent = i;
                col.appendChild(val);
            }
            el.appendChild(col);
        }
        // Khởi tạo trạng thái ban đầu (không hiệu ứng)
        renderOdometer(el, value, true);
    }

    function renderOdometer(el, value, instant = false) {
        const str = value.toString();
        
        // Kiểm tra thay đổi số lượng chữ số (vd: 9 -> 10)
        if (el.children.length !== str.length) {
            setupOdometer(el, value);
            return;
        }

        const cols = el.children;
        str.split('').forEach((digit, idx) => {
            const num = parseInt(digit);
            const col = cols[idx];
            
            if (instant) col.style.transition = 'none';
            else col.style.transition = 'transform 0.8s cubic-bezier(0.45, 0.05, 0.55, 0.95)';

            const currentPos = col.getAttribute('data-val');
            if (currentPos !== digit) {
                if (!instant) col.classList.add('is-rolling');
                col.style.transform = `translateY(-${num * 1.3}em)`;
                col.setAttribute('data-val', digit);
                
                if (!instant) {
                    setTimeout(() => col.classList.remove('is-rolling'), 800);
                }
            }
        });
    }

    function startLiveUpdates(id, initVal) {
        let val = initVal;
        const container = document.getElementById(id);
        function next() {
            const delay = Math.floor(Math.random() * 5000) + 2000;
            setTimeout(() => {
                val += Math.floor(Math.random() * 2) + 1;
                renderOdometer(container, val);
                next();
            }, delay);
        }
        next();
    }

    document.addEventListener('DOMContentLoaded', initOdometers);
</script>
