@model ASM.Models.Product
@{
    ViewData["Title"] = Model.ProductName + " - Bread & Brew";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    string GetDetailImagePath(string? img) {
        if (string.IsNullOrEmpty(img)) return "/Images/default.png";
        if (img.Contains("http")) return img;
        var clean = img.Replace("/Images/", "").Replace("Images/", "").TrimStart('/');
        return "/Images/" + clean;
    }

    var dbReviews = Model.Reviews?.OrderByDescending(r => r.ReviewId).ToList() ?? new List<ASM.Models.Review>();
    
    // Khôi phục dữ liệu mẫu (Mock Data)
    var mockReviews = new List<ASM.Models.Review> {
        new ASM.Models.Review { 
            User = new ASM.Models.User { FullName = "Hương Ly" }, 
            Rating = 5, 
            Comment = "Trời ơi món này siêu đỉnh! Vị đậm đà, chuẩn gu nhà mình luôn. Đánh giá 5 sao không nói nhiều!", 
            CreatedAt = DateTime.Now.AddDays(-2) 
        },
        new ASM.Models.Review { 
            User = new ASM.Models.User { FullName = "Tuấn Phong" }, 
            Rating = 4, 
            Comment = "Đồ uống khá ngon, đóng gói rất cẩn thận và đẹp mắt. Sẽ tiếp tục ủng hộ quán.", 
            CreatedAt = DateTime.Now.AddDays(-5) 
        }
    };
    
    // Gộp dữ liệu thật và dữ liệu mẫu
    var reviews = dbReviews.Concat(mockReviews).ToList();
    var avgRating = reviews.Any() ? reviews.Average(r => r.Rating) : 5;

    // CUSTOM DESCRIPTION GENERATOR (Base on User Request Image 4)
    string GetCustomDescription(string name) {
        name = name.ToLower();
        if (name.Contains("muối")) 
            return "Khám phá sự kết hợp độc đáo giữa vị cà phê đậm đà và chút mặn nhẹ của kem muối lớp trên cùng. Đây là bước đột phá trong hương vị, tạo nên sự cân bằng hoàn hảo giữa đắng, ngọt và mặn, đánh thức mọi giác quan của bạn ngay từ ngụm đầu tiên.\n\nChúng tôi thấu hiểu từng nhu cầu và luôn cố gắng đáp ứng bằng sự tận tâm. Sản phẩm này là một trong những món được khách hàng yêu thích nhất tại hệ thống vì chất lượng nhất quán, tạo nên điểm nhấn tinh tế giữa nhịp sống bận rộn.";
        
        if (name.Contains("matcha"))
            return "Sự kết hợp tinh tế giữa bột trà xanh Matcha chuẩn Nhật Bản và sữa tươi thanh trùng béo ngậy. Matcha Latte không chỉ mang lại màu xanh dịu mát mắt mà còn là nguồn năng lượng sạch, giàu chất chống oxy hóa giúp bạn tỉnh táo và thư giãn tối đa.\n\nBread & Brew cam kết mang đến chất lượng tốt nhất trong mọi công đoạn từ lúc chọn nguyên liệu trà cho đến khi thành phẩm thơm ngon đến tay bạn.";

        if (name.Contains("tiramisu"))
            return "Một sự biến tấu đầy kiêu hãnh của món tráng miệng Ý cổ điển vào ly cà phê hiện đại. Lớp kem trứng sánh mịn hòa quyện cùng cốt cà phê espresso đậm đặc và bột cacao cao cấp, mang đến một hành trình hương vị đầy mê hoặc.\n\nSản phẩm này là minh chứng cho sự tỉ mỉ của các Barista chúng tôi, đảm bảo mỗi ly đều là một tác phẩm nghệ thuật chuẩn vị.";

        // Default high-quality description
        return $"Khám phá hương vị đặc biệt của {Model.ProductName}. Sự kết hợp hoàn hảo của các thành phần tự nhiên tạo nên một trải nghiệm tuyệt vời, không chỉ đánh thức vị giác mà còn khơi gợi nguồn cảm hứng bất tận dành cho bạn mỗi ngày.\n\nBread & Brew cam kết mang đến chất lượng tốt nhất trong mọi công đoạn từ lúc chọn nguyên liệu cho đến khi thành phẩm đến tay bạn. Chúng tôi thấu hiểu từng nhu cầu và luôn cố gắng đáp ứng bằng sự tận tâm.";
    }

    string customDesc = GetCustomDescription(Model.ProductName);
}

<style>
    :root {
        --bb-dark: #23150D;
        --bb-amber: #EA580C;
        --bb-tan: #D6A87C;
        --bb-bg: #fdf6f0;
        --bb-text: #23150D;
    }

    body { background-color: var(--bb-bg); color: var(--bb-text); margin: 0; }

    /* --- PRODUCT MAIN --- */
    .p-detail-wrapper { padding: 140px 20px 80px; max-width: 1200px; margin: 0 auto; }
    .p-main-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 60px; margin-bottom: 80px; }

    .p-thumb-col { display: flex; flex-direction: column; gap: 15px; }
    .p-thumb-item { width: 100%; aspect-ratio: 1; border-radius: 12px; overflow: hidden; border: 2px solid transparent; cursor: pointer; transition: 0.3s; background: #fff; padding: 5px; box-shadow: 0 4px 10px rgba(0,0,0,0.03); }
    .p-thumb-item.active { border-color: var(--bb-amber); }
    .p-thumb-item img { width: 100%; height: 100%; object-fit: contain; }

    .p-main-display { background: #fff; border-radius: 32px; padding: 40px; display: flex; align-items: center; justify-content: center; box-shadow: 0 20px 60px rgba(0,0,0,0.05); height: 550px; }
    .p-main-display img { max-width: 100%; max-height: 100%; object-fit: contain; transition: 0.5s ease; }
    .p-main-display:hover img { transform: scale(1.05); }

    .p-info-col { padding-top: 10px; }
    .p-title { font-size: 3.5rem; font-weight: 900; color: var(--bb-dark); line-height: 1.1; margin-bottom: 10px; }
    .p-stars-row { display: flex; align-items: center; gap: 10px; margin-bottom: 25px; color: #fbbf24; font-size: 1.1rem; }
    .p-stars-row span { color: #94a3b8; font-weight: 500; }

    .p-price-big { font-size: 3.2rem; font-weight: 900; color: var(--bb-amber); margin-bottom: 30px; letter-spacing: -1px; }
    .p-desc { line-height: 1.8; color: #475569; font-size: 1.05rem; margin-bottom: 30px; white-space: pre-wrap; }

    /* Feature List from Image 1 */
    .p-feature-list { list-style: none; padding: 0; margin: 0 0 35px 0; border-top: 1px solid #eee; padding-top: 25px; }
    .p-feature-item { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; font-weight: 600; font-size: 1.05rem; color: var(--bb-dark); }
    .p-feature-item i { color: var(--bb-amber); font-size: 0.9rem; }

    .p-actions { display: flex; align-items: center; gap: 25px; margin-bottom: 45px; }
    .p-qty-box { display: flex; align-items: center; background: #fff; border: 1px solid #e2e8f0; border-radius: 40px; padding: 8px 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); }
    .p-qty-btn { background: none; border: none; font-size: 1.4rem; cursor: pointer; font-weight: 700; width: 35px; height: 45px; color: var(--bb-dark); }
    .p-qty-inp { width: 50px; border: none; text-align: center; font-weight: 900; font-size: 1.25rem; outline: none; background: transparent; color: var(--bb-dark); }
    .p-add-btn { flex: 1; background: var(--bb-amber); color: #fff; border: none; padding: 20px 40px; border-radius: 40px; font-weight: 800; font-size: 1.1rem; text-transform: uppercase; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 25px rgba(234, 88, 12, 0.3); }
    .p-add-btn:hover { background: #b45309; transform: translateY(-3px); box-shadow: 0 15px 30px rgba(234, 88, 12, 0.4); }

    .p-meta { font-size: 0.95rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    .p-meta b { color: var(--bb-dark); margin-left: 5px; }

    /* --- TABS --- */
    .p-tabs { margin-top: 80px; }
    .p-tabs-header { display: flex; gap: 60px; border-bottom: 2px solid #f1f5f9; position: relative; }
    .p-tab-trigger { padding: 20px 0; cursor: pointer; font-weight: 800; color: #94a3b8; transition: 0.3s; font-size: 1.1rem; text-transform: uppercase; border-bottom: 4px solid transparent; margin-bottom: -2px; }
    .p-tab-trigger.active { color: var(--bb-amber); border-bottom-color: var(--bb-amber); }
    .p-tab-content { padding: 60px 0; display: none; }
    .p-tab-content.active { display: block; animation: fadeInTab 0.5s ease forwards; }
    @@keyframes fadeInTab { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .custom-desc-text { 
        line-height: 2; 
        color: #475569; 
        font-size: 1.2rem; 
        white-space: pre-wrap; 
        max-width: 900px;
    }

    /* --- REVIEWS --- */
    .rev-card { display: flex; gap: 25px; padding: 35px; background: #fff; border-radius: 24px; margin-bottom: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
    
    .rev-form-container { background: #fff; padding: 35px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); margin-bottom: 40px; }
    .rev-form-title { font-size: 1.5rem; font-weight: 800; color: var(--bb-dark); margin-bottom: 20px; }
    .star-rating-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 12px;
        font-size: 2.5rem;
        margin-bottom: 5px;
    }
    .star-item {
        color: #e2e8f0;
        cursor: pointer;
        transition: transform 0.2s, color 0.2s;
    }
    .star-item:hover {
        transform: scale(1.2);
    }
    .star-item.active, 
    .star-item.active ~ .star-item,
    .star-item:hover, 
    .star-item:hover ~ .star-item {
        color: #fbbf24 !important;
    }

    .rev-textarea { width: 100%; border: 2px solid #e2e8f0; border-radius: 12px; padding: 15px; font-size: 1rem; color: var(--bb-dark); outline: none; transition: 0.3s; margin-bottom: 20px; min-height: 100px; resize: vertical; }
    .rev-textarea:focus { border-color: var(--bb-amber); }
    .btn-submit-rev { background: var(--bb-amber); color: #fff; border: none; padding: 12px 30px; border-radius: 30px; font-weight: 700; cursor: pointer; transition: 0.3s; }
    .btn-submit-rev:hover { background: #b45309; transform: translateY(-2px); }
    .rev-avatar { width: 60px; height: 60px; background: linear-gradient(135deg, var(--bb-tan), var(--bb-dark)); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 900; font-size: 1.4rem; }
    .rev-name { font-weight: 800; color: var(--bb-dark); margin-right: 15px; font-size: 1.1rem; }
    .rev-date { color: #94a3b8; font-size: 0.9rem; }
    .rev-stars i {
        color: #fbbf24;
        font-size: 0.9rem;
    }
    .rev-stars i.fa-regular {
        color: #e2e8f0; /* Màu xám cho sao rỗng */
    }
    .rev-stars { margin: 10px 0; }
    .rev-text { color: #64748b; line-height: 1.8; font-size: 1.05rem; }

    .rating-label { font-weight: 800; color: var(--bb-amber); font-size: 1.3rem; margin-bottom: 25px; display: block; }

    .rev-textarea { width: 100%; border: 1px solid #e2e8f0; border-radius: 20px; padding: 25px; min-height: 160px; font-family: inherit; margin-bottom: 30px; outline: none; transition: 0.3s; font-size: 1.1rem; background: #f8fafc; }
    .rev-textarea:focus { border-color: var(--bb-amber); background: #fff; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .rev-submit-btn { background: var(--bb-dark); color: #fff; border: none; padding: 18px 50px; border-radius: 40px; font-weight: 800; cursor: pointer; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; }
    .rev-submit-btn:hover { background: #000; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

    .btn-load-more {
        background: transparent;
        color: var(--bb-amber);
        border: 2px solid var(--bb-amber);
        padding: 12px 40px;
        border-radius: 30px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .btn-load-more:hover {
        background: var(--bb-amber);
        color: #fff;
        box-shadow: 0 8px 20px rgba(234, 88, 12, 0.2);
    }

    /* --- RELATED SLIDER --- */
    .p-related-section { margin-top: 100px; padding: 60px 0; border-top: 1px solid rgba(0,0,0,0.05); }
    .p-related-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
    .p-related-title { font-size: 1.8rem; font-weight: 800; color: var(--bb-dark); margin: 0; letter-spacing: -0.5px; }
    
    .rel-nav { display: flex; gap: 12px; }
    .rel-nav-btn { width: 40px; height: 40px; border-radius: 50%; border: 1.5px solid #e2e8f0; background: #fff; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--bb-dark); }
    .rel-nav-btn:hover { background: var(--bb-amber); color: #fff; border-color: var(--bb-amber); transform: scale(1.1); }
    
    .rel-slider-container { position: relative; overflow: hidden; padding: 10px 0; }
    .rel-slider-track { display: flex; gap: 30px; overflow-x: auto; padding: 20px 5px; scrollbar-width: none; scroll-behavior: smooth; }
    .rel-slider-track::-webkit-scrollbar { display: none; }
    
    .rel-card { 
        min-width: calc(33.333% - 20px); 
        background: #fff; 
        border-radius: 24px; 
        padding: 25px; 
        text-align: center; 
        border: 1px solid rgba(0,0,0,0.04); 
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        flex-shrink: 0; 
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        position: relative;
        overflow: hidden;
    }
    .rel-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-color: rgba(234, 88, 12, 0.2); }
    
    .rel-img-box { height: 180px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; border-radius: 16px; background: #fafafa; transition: 0.3s; }
    .rel-img-box img { width: 85%; height: 85%; object-fit: contain; transition: 0.5s; }
    .rel-card:hover .rel-img-box img { transform: scale(1.1) rotate(3deg); }
    
    .rel-title-link { font-weight: 800; color: var(--bb-dark); text-decoration: none; margin-bottom: 8px; display: block; font-size: 1.05rem; transition: 0.3s; }
    .rel-price-tag { color: var(--bb-amber); font-weight: 900; font-size: 1.15rem; margin-bottom: 15px; display: block; }
    
    .rel-add-btn { 
        background: var(--bb-dark); color: #fff; border: none; padding: 10px 20px; border-radius: 30px; 
        font-weight: 800; font-size: 0.85rem; cursor: pointer; transition: 0.3s; 
        opacity: 0; transform: translateY(10px); width: 100%;
    }
    .rel-card:hover .rel-actions { opacity: 1 !important; transform: translateY(0) !important; }
    .rel-add-btn:hover { background: var(--bb-amber); color:#fff; }
    @@media(max-width: 768px) { .rel-card { min-width: 100%; } }

    /* --- BACK TO TOP --- */
    #btnBackToTop {
        position: fixed;
        bottom: 40px;
        right: 40px;
        width: 55px;
        height: 55px;
        background: var(--bb-amber);
        color: white;
        border: none;
        border-radius: 50%;
        display: none;
        justify-content: center;
        align-items: center;
        font-size: 1.4rem;
        cursor: pointer;
        z-index: 1000;
        box-shadow: 0 5px 20px rgba(234,88,12,0.4);
        transition: 0.3s;
    }
    #btnBackToTop:hover {
        background: #b45309;
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(234,88,12,0.6);
    }

    /* --- SCROLL DOWN --- */
    #btnScrollDown {
        position: fixed;
        bottom: 110px;
        right: 40px;
        width: 55px;
        height: 55px;
        background: var(--bb-dark);
        color: white;
        border: none;
        border-radius: 50%;
        display: none;
        justify-content: center;
        align-items: center;
        font-size: 1.4rem;
        cursor: pointer;
        z-index: 1000;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        transition: 0.3s;
    }
    #btnScrollDown:hover {
        background: #000;
        transform: translateY(5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }
</style>

<div class="p-detail-wrapper">
    <div class="p-main-grid">

        <div class="p-main-display">
            <img src="@GetDetailImagePath(Model.Image)" id="dispImg" />
        </div>
        <div class="p-info-col">
            <h1 class="p-title">@Model.ProductName</h1>
            <div class="p-stars-row">
                <div>
                     @for (int i = 1; i <= 5; i++) { <i class="fa-solid fa-star @(i <= Math.Round(avgRating) ? "" : "fa-regular")"></i> }
                </div>
                <span>(@reviews.Count nhận xét)</span>
            </div>
            
            <div class="p-price-big">@Model.Price.ToString("N0")đ</div>

            <div class="p-desc">@customDesc</div>

            <!-- FEATURE LIST -->
            <ul class="p-feature-list">
                <li class="p-feature-item"><i class="fa-solid fa-check"></i> Nguyên liệu sạch 100% tự nhiên</li>
                <li class="p-feature-item"><i class="fa-solid fa-check"></i> Công thức độc quyền Bread & Brew</li>
                <li class="p-feature-item"><i class="fa-solid fa-check"></i> Hương vị hoàn hảo chuẩn gu hiện đại</li>
            </ul>

            <div class="p-actions">
                <div class="p-qty-box">
                    <button class="p-qty-btn" onclick="uQty(-1)">-</button>
                    <input type="number" id="qInp" value="1" class="p-qty-inp" readonly />
                    <button class="p-qty-btn" onclick="uQty(1)">+</button>
                </div>
                <button class="p-add-btn" onclick="addToCart(@Model.ProductId, document.getElementById('qInp').value)" style="background:#23150D; box-shadow:none;">Thêm vào giỏ</button>
                <a href="/Cart/BuyNow?productId=@Model.ProductId&quantity=1" id="buyNowBtn" class="p-add-btn" style="text-align:center; text-decoration:none; display:flex; align-items:center; justify-content:center;">MUA NGAY</a>
            </div>

            <div class="p-meta">
                SKU:<b>BB-@Model.ProductId.ToString("D3")</b> &nbsp; | &nbsp; Category:<b>@(Model.Category?.CategoryName ?? "Menu")</b>
            </div>
        </div>
    </div>

    <!-- REVIEWS SECTION -->
    <div class="p-tabs">
        <h2 style="font-size: 2.2rem; font-weight: 900; color: var(--bb-dark); margin-bottom: 40px; text-transform: uppercase;">Đánh giá từ khách hàng (@reviews.Count)</h2>

        <!-- Form Viết Đánh Giá -->
        @if (ViewBag.CanReview == true)
        {
            <form id="reviewForm" action="/Home/SubmitReview" method="post" class="rev-form-container">
                <h3 class="rev-form-title">Đề lại cảm nhận của bạn</h3>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; background: #fffaf5; padding: 20px; border-radius: 15px; border: 1px solid #ffe4d6;">
                    <span id="starTextLabel" style="font-weight: 800; color: #ea580c; font-size: 1.4rem;">Tuyệt vời</span>
                    <input type="hidden" name="rating" id="selectedRating" value="5" />
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <div class="star-rating-input" id="starContainer">
                        <i class="fa-solid fa-star star-item active" data-value="5" title="Tuyệt vời"></i>
                        <i class="fa-solid fa-star star-item active" data-value="4" title="Tốt"></i>
                        <i class="fa-solid fa-star star-item active" data-value="3" title="Ổn"></i>
                        <i class="fa-solid fa-star star-item active" data-value="2" title="Tệ"></i>
                        <i class="fa-solid fa-star star-item active" data-value="1" title="Rất tệ"></i>
                    </div>
                </div>

                <textarea name="comment" id="revComment" class="rev-textarea" placeholder="Chia sẻ cảm nhận của bạn về hương vị món này..." required></textarea>
                <button type="submit" class="rev-submit-btn">GỬI ĐÁNH GIÁ</button>
            </form>
        }
        else
        {
            <div class="rev-form-container" style="background: #f1f5f9; border: 2px dashed #cbd5e1; text-align: center; padding: 40px;">
                <i class="fa-solid fa-lock" style="font-size: 2.5rem; color: #94a3b8; margin-bottom: 15px;"></i>
                <h4 style="color: #64748b; font-weight: 800; margin-bottom: 10px;">ĐÁNH GIÁ ĐÃ BỊ KHÓA</h4>
                <p style="color: #94a3b8; font-size: 1rem;">Bạn chỉ có thể đánh giá sản phẩm này sau khi đã mua hàng và đơn hàng được giao thành công.</p>
            </div>
        }

        <!-- Danh sách Đánh Giá -->
        <div id="reviewsList">
            @if(reviews.Any()) {
                int count = 0;
                foreach (var r in reviews) {
                    count++;
                    <div class="rev-card @(count > 5 ? "rev-hidden" : "")" style="@(count > 5 ? "display:none;" : "")">
                        <div class="rev-avatar">@(r.User?.FullName?[0] ?? 'K')</div>
                        <div class="rev-main">
                            <div><span class="rev-name">@r.User?.FullName</span> <span class="rev-date">@r.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                            <div class="rev-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="@(i <= r.Rating ? "fa-solid" : "fa-regular") fa-star"></i>
                                }
                            </div>
                            <p class="rev-text">@r.Comment</p>
                        </div>
                    </div>
                }

                if (reviews.Count > 5)
                {
                    <div style="text-align: center; margin-top: 20px;">
                        <button id="btnShowMore" class="btn-load-more" onclick="toggleReviews()" data-expanded="false" data-count="@(reviews.Count - 5)">
                            XEM THÊM ĐÁNH GIÁ (CÒN @(reviews.Count - 5) LƯỢT) <i class="fa-solid fa-chevron-down ms-2"></i>
                        </button>
                    </div>
                }
            } else {
                <div style="text-align: center; padding: 40px; color: #94a3b8;">Chưa có đánh giá nào cho món này.</div>
            }
        </div>
    </div>


    </div>

    <div class="p-related-section">
        <div class="p-related-header">
            <h2 class="p-related-title">Sản phẩm <b>tương tự</b></h2>
            <div class="rel-nav">
                <button class="rel-nav-btn" onclick="relScroll(-1)"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="rel-nav-btn" onclick="relScroll(1)"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
        <div class="rel-slider-container">
            <div class="rel-slider-track" id="relTrack">
                @if (ViewBag.RelatedProducts != null) {
                    foreach (var item in (IEnumerable<ASM.Models.Product>)ViewBag.RelatedProducts) {
                        <div class="rel-card">
                            <a href="/Home/Detail/@item.ProductId" style="text-decoration:none; color:inherit;">
                                <div class="rel-img-box">
                                    <img src="@GetDetailImagePath(item.Image)" onerror="this.src='/Images/default.png'" />
                                </div>
                                <div class="rel-title-link">@item.ProductName</div>
                                <div class="rel-price-tag">@item.Price.ToString("N0")đ</div>
                            </a>
                            <div style="display:flex; gap:10px; opacity: 0; transform: translateY(10px); transition: 0.3s;" class="rel-actions">
                                <button class="rel-add-btn" onclick="addToCart(@item.ProductId)" style="flex:1; transform:none; opacity:1; padding:10px 0; background:#f1f5f9; color:#23150D;">
                                    <i class="fa-solid fa-cart-plus"></i>
                                </button>
                                <a href="/Cart/BuyNow?productId=@item.ProductId" class="rel-add-btn" style="flex:2; transform:none; opacity:1; padding:10px 0; text-align:center; text-decoration:none;">
                                    MUA NGAY
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Back to Top & Scroll Down Buttons -->
<div class="fixed-nav-btns">
    <button id="btnScrollDown" onclick="scrollToRevBtn()" title="Xem hết đánh giá">
        <i class="fa-solid fa-arrow-down"></i>
    </button>
    <button id="btnBackToTop" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" title="Lên đầu trang">
        <i class="fa-solid fa-arrow-up"></i>
    </button>
</div>

<script>
    function setDispImg(el, src) {
        document.querySelectorAll('.p-thumb-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('dispImg').src = src;
    }
    function uQty(d) {
        let i = document.getElementById('qInp');
        let v = parseInt(i.value) + d;
        if (v >= 1 && v <= 50) {
            i.value = v;
            // Cập nhật số lượng vào link Mua Ngay
            let buyBtn = document.getElementById('buyNowBtn');
            if(buyBtn) buyBtn.href = '/Cart/BuyNow?productId=@Model.ProductId&quantity=' + v;
        }
    }
    function sTab(el, id) {
        document.querySelectorAll('.p-tab-trigger').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.p-tab-content').forEach(c => c.classList.remove('active'));
        el.classList.add('active');
        document.getElementById(id).classList.add('active');
    }

    /* Slider logic - Infinite Loop */
    function relScroll(dir) {
        const track = document.getElementById('relTrack');
        if (!track) return;
        const card = track.querySelector('.rel-card');
        if (!card) return;
        const amount = card.offsetWidth + 30; // Chiều rộng 1 card + gap 30px
        const maxScrollLeft = track.scrollWidth - track.clientWidth;

        if (dir === 1) { // Click Next
            if (track.scrollLeft >= maxScrollLeft - 10) {
                // Tới cuối thì vòng lại đầu
                track.scrollTo({ left: 0, behavior: 'smooth' });
            } else {
                track.scrollBy({ left: amount, behavior: 'smooth' });
            }
        } else { // Click Prev
            if (track.scrollLeft <= 10) {
                // Đang ở đầu thì lùi đến cuối
                track.scrollTo({ left: maxScrollLeft, behavior: 'smooth' });
            } else {
                track.scrollBy({ left: -amount, behavior: 'smooth' });
            }
        }
    }

    /* Cập nhật chữ diễn giải mức độ hài lòng */
    const starLabels = { 1: "Rất tệ", 2: "Tệ", 3: "Ổn", 4: "Tốt", 5: "Tuyệt vời" };
    
    // Khởi tạo sự kiện cho các ngôi sao
    document.addEventListener('DOMContentLoaded', function() {
        const stars = document.querySelectorAll('.star-item');
        const ratingInput = document.getElementById('selectedRating');
        const textLabel = document.getElementById('starTextLabel');
        const starLabels = { 1: "Rất tệ", 2: "Tệ", 3: "Ổn", 4: "Tốt", 5: "Tuyệt vời" };

        stars.forEach(star => {
            star.addEventListener('click', function() {
                const val = parseInt(this.getAttribute('data-value'));
                ratingInput.value = val;
                textLabel.innerText = starLabels[val];
                
                // Cập nhật trạng thái active cho chính nó và các sao THẤP hơn (về bên phải visual)
                stars.forEach(s => {
                    const sVal = parseInt(s.getAttribute('data-value'));
                    if (sVal <= val) {
                        s.classList.add('active');
                    } else {
                        s.classList.remove('active');
                    }
                });
            });
        });

        // Xử lý gửi form bằng Ajax
        const form = document.getElementById('reviewForm');
        if(form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                
                fetch(this.action, {
                    method: 'POST',
                    body: new URLSearchParams(formData)
                })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        Swal.fire({ 
                            icon: 'success', 
                            title: 'Thành công', 
                            text: data.message,
                            confirmButtonColor: '#EA580C' 
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message, confirmButtonColor: '#EA580C' });
                    }
                })
                .catch(err => {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Có lỗi xảy ra khi gửi.', confirmButtonColor: '#EA580C' });
                });
            });
        }
    });

    function toggleReviews() {
        const hiddenReviews = document.querySelectorAll('.rev-hidden');
        const btn = document.getElementById('btnShowMore');
        if (!btn) return;

        const isExpanded = btn.getAttribute('data-expanded') === 'true';
        const remainingCount = btn.getAttribute('data-count');

        if (!isExpanded) {
            // Mở rộng
            hiddenReviews.forEach(rev => {
                rev.style.display = 'flex';
                rev.classList.add('fade-up-init');
                setTimeout(() => rev.classList.remove('fade-up-init'), 10);
            });
            btn.innerHTML = 'THU GỌN ĐÁNH GIÁ <i class="fa-solid fa-chevron-up ms-2"></i>';
            btn.setAttribute('data-expanded', 'true');
        } else {
            // Thu gọn
            hiddenReviews.forEach(rev => {
                rev.style.display = 'none';
            });
            btn.innerHTML = `XEM THÊM ĐÁNH GIÁ (CÒN ${remainingCount} LƯỢT) <i class="fa-solid fa-chevron-down ms-2"></i>`;
            btn.setAttribute('data-expanded', 'false');
            
            // Tự động cuộn trang lên trên khu vực đánh giá một chút
            const reviewTop = document.querySelector('.p-tabs').offsetTop - 100;
            window.scrollTo({ top: reviewTop, behavior: 'smooth' });
        }
    }

    // Logic Ẩn/Hiện nút Back To Top & Scroll Down
    window.addEventListener('scroll', function() {
        const btnTop = document.getElementById('btnBackToTop');
        const btnDown = document.getElementById('btnScrollDown');
        const showMoreBtn = document.getElementById('btnShowMore');

        if (btnTop) {
            if (window.scrollY > 400) {
                btnTop.style.display = 'flex';
                // Chỉ hiện nút cuộn xuống khi đang có danh sách mở rộng và chưa cuộn tới cuối nút đó
                if (showMoreBtn && showMoreBtn.getAttribute('data-expanded') === 'true') {
                    const rect = showMoreBtn.getBoundingClientRect();
                    if (rect.top > window.innerHeight) {
                        btnDown.style.display = 'flex';
                    } else {
                        btnDown.style.display = 'none';
                    }
                } else {
                    btnDown.style.display = 'none';
                }
            } else {
                btnTop.style.display = 'none';
                btnDown.style.display = 'none';
            }
        }
    });

    function scrollToRevBtn() {
        const btn = document.getElementById('btnShowMore');
        if (btn) {
            const top = btn.offsetTop - (window.innerHeight / 2);
            window.scrollTo({ top: top, behavior: 'smooth' });
        }
    }
</script>