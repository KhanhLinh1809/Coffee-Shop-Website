@{
    ViewData["Title"] = "Đăng nhập - Bread & Brew";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<style>
    .auth-wrapper { min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 60px 20px; background-color: #C8A880; }
    
    /* ĐÃ XÓA KHUNG TRẮNG VÀ LÀM TO RA */
    .auth-card { 
        background: transparent; 
        border: none; 
        box-shadow: none; 
        width: 100%; 
        max-width: 550px; /* Form to và rộng hơn */
        padding: 0; 
    }
    
    .auth-title { text-align: center; color: #2C1A0E; font-weight: 900; font-size: 3rem; margin-bottom: 10px; text-transform: uppercase; }
    .auth-subtitle { text-align: center; color: #4A3020; margin-bottom: 40px; font-size: 1.1rem; font-weight: 500; }
    
    .form-group { margin-bottom: 25px; }
    .form-group label { display: block; font-weight: 800; color: #2C1A0E; margin-bottom: 10px; font-size: 16px; }
    
    /* Ô nhập liệu to, bo góc mềm mại, có bóng mờ nhẹ để nổi bật trên nền */
    .form-control { 
        width: 100%; padding: 18px 20px; 
        border: 2px solid rgba(44, 26, 14, 0.1); border-radius: 16px; 
        font-size: 16px; transition: 0.3s; background: #fff; color: #1e293b; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .form-control:focus { border-color: #EA580C; box-shadow: 0 0 0 5px rgba(234, 88, 12, 0.15); outline: none; }
    
    /* Nút bấm siêu to khổng lồ */
    .btn-auth { 
        width: 100%; padding: 18px; background: #EA580C; color: white; border: none; 
        border-radius: 16px; font-weight: 900; font-size: 18px; cursor: pointer; 
        transition: 0.3s; margin-top: 15px; text-transform: uppercase; letter-spacing: 1px;
        box-shadow: 0 10px 25px rgba(234, 88, 12, 0.4);
    }
    .btn-auth:hover { background: #C2410C; transform: translateY(-3px); box-shadow: 0 15px 30px rgba(234, 88, 12, 0.5); }
    
    .auth-links { text-align: center; margin-top: 30px; font-weight: 700; color: #4A3020; font-size: 16px; }
    .auth-links a { color: #EA580C; text-decoration: none; transition: 0.2s; font-weight: 800; }
    .auth-links a:hover { color: #2C1A0E; text-decoration: underline; }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">ĐĂNG NHẬP</h2>
        <p class="auth-subtitle">Chào mừng bạn quay trở lại!</p>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div style="background: #FEE2E2; color: #B91C1C; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-weight: 700; font-size: 15px; text-align: center; border: 1px solid #FECACA;">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label>Email đăng nhập</label>
                <input type="email" name="Email" class="form-control" placeholder="Nhập địa chỉ email..." required>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="Password" class="form-control" placeholder="Nhập mật khẩu..." required>
            </div>

            <button type="submit" class="btn-auth">ĐĂNG NHẬP</button>
        </form>

        <div class="auth-links">
            Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</div>