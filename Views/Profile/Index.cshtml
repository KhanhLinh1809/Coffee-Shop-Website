@model ASM.Models.User
@{
    ViewData["Title"] = "Trang cá nhân";
}

<style>
    /* Wrapper bao quanh để căn giữa Card mà không phá Layout */
    .profile-wrapper {
        background: linear-gradient(135deg, #3e2723 0%, #b58363 100%);
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        width: 100%;
        max-width: 550px;
        padding: 40px;
        border-radius: 30px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .profile-card h2 {
        text-align: center;
        color: #3e2723;
        margin-bottom: 30px;
        font-weight: 800;
    }

    #preview {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; font-weight: bold; margin-bottom: 5px; color: #555; }
    
    .form-control {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #ddd;
        font-size: 15px;
    }

    .btn-save {
        width: 100%;
        padding: 15px;
        background: linear-gradient(135deg, #fb8c00, #ff5722);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 20px;
        transition: 0.3s;
    }

    .btn-save:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(251,140,0,0.4); }
</style>

<div class="profile-wrapper">
    <div class="profile-card">
        <h2>👤 Thông tin cá nhân</h2>

        @if (ViewBag.Message != null)
        {
            <div style="background:#d4edda; color:#155724; padding:10px; border-radius:10px; margin-bottom:15px; text-align:center;">
                @ViewBag.Message
            </div>
        }

        <form asp-action="Index" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Email" />

            <div style="text-align: center; margin-bottom: 25px;">
                <img id="preview" src="@(string.IsNullOrEmpty(Model.Avatar) ? "/Images/default.png" : Model.Avatar)?v=@DateTime.Now.Ticks" />
                <div style="margin-top: 10px;">
                    <label style="background:#eee; padding:5px 15px; border-radius:20px; cursor:pointer; font-size:13px;">
                        Đổi ảnh đại diện
                        <input type="file" name="avatarFile" hidden onchange="previewImage(event)" accept="image/*" />
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label>Họ và tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên..." required />
            </div>

            <div class="form-group">
                <label>Email (Không thể đổi)</label>
                <input asp-for="Email" class="form-control" style="background:#f0f0f0" readonly disabled />
            </div>

            <div class="form-group">
                <label>Số điện thoại</label>
                <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại (10-11 số)..." 
                       maxlength="11" oninput="this.value = this.value.replace(/[^0-9+]/g, '')" />
            </div>

            <div class="form-group">
                <label>Địa chỉ</label>
                <textarea asp-for="Address" class="form-control" rows="2" maxlength="200" placeholder="Nhập địa chỉ của bạn..."
                          oninput="this.value = this.value.replace(/[!@@#$%^&*()_+={}\[\]|\\:;&quot;'<>\?~`]/g, '')"></textarea>
            </div>

            <button type="submit" class="btn-save">💾 Lưu thay đổi</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function(){
                const output = document.getElementById('preview');
                output.src = reader.result;
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}
