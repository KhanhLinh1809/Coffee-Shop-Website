@model ASM.Models.Order
@{
    bool isConfirm = ViewBag.IsConfirm ?? false;
    ViewData["Title"] = isConfirm ? "Xác nhận đơn hàng" : "Chi tiết đơn hàng";

    // Khai báo sẵn các biến hỗ trợ để tránh viết code phức tạp trong HTML
    string statusText = "";
    string statusDesc = "";
    string statusIcon = "";
    string progressWidth = "0%";
    bool showTime = false;
    string timeRange = "";

    if (!isConfirm)
    {
        statusText = Model.OrderStatus switch { 1=>"Đã xác nhận", 2=>"Đang chuẩn bị", 3=>"Đang giao", 4=>"Đã giao", 5=>"Đã hủy", _=>"Đang cập nhật" };
        statusDesc = Model.OrderStatus switch {
            1 => "Hệ thống đã tiếp nhận đơn hàng của bạn và đang chờ xử lý.",
            2 => "Cửa hàng đang tiến hành pha chế/đóng gói",
            3 => "Tài xế đã nhận món và đang trên đường tới bạn",
            4 => "Chúc bạn ngon miệng với Bread & Brew!",
            5 => "Đơn hàng của bạn đã bị hủy.",
            _ => "Đang cập nhật..."
        };
        statusIcon = Model.OrderStatus switch { 1=>"fa-file-invoice", 2=>"fa-mug-hot", 3=>"fa-truck-fast", 4=>"fa-circle-check", _=>"fa-circle-info" };
        progressWidth = Model.OrderStatus == 5 ? "0%" : (Model.OrderStatus == 1 ? "0%" : (Model.OrderStatus == 2 ? "33.33%" : (Model.OrderStatus == 3 ? "66.66%" : "100%")));
        
        // Luôn tính toán thời gian dự kiến để hiển thị cho đẹp
        Random rnd = new Random(Model.OrderId);
        int startMin = rnd.Next(10, 20);
        int endMin = startMin + rnd.Next(10, 15);
        timeRange = $"{Model.CreatedAt.AddMinutes(startMin):HH:mm} - {Model.CreatedAt.AddMinutes(endMin):HH:mm}";
        showTime = true;
    }
}

<link rel="stylesheet" href="~/css/Order.css" />

<div class="order-full-page" style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/Images/Redesign/cafe_bg.jpg'); background-size: cover; background-position: center; background-attachment: fixed; flex: 1; padding: 40px 0; font-family: 'Inter', sans-serif; color: #fff; display: flex; flex-direction: column;">
    <div class="order-container" style="max-width: 1240px; margin: 0 auto; padding: 0 20px; background: transparent !important; box-shadow: none !important;">
        
        <!-- HEADER BUTTON (GRAY GLASSMORPISM) -->
        <div style="margin-bottom: 30px;">
            <a href="@(isConfirm ? "javascript:history.back()" : "/Order/Index")" style="display: inline-flex; align-items: center; gap: 10px; padding: 10px 20px; background: rgba(255,255,255,0.25); color: #fff; border-radius: 50px; text-decoration: none; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.3); backdrop-filter: blur(10px);">
                <i class="fa-solid fa-arrow-left"></i> @(isConfirm ? "QUAY LẠI" : "QUAY LẠI DANH SÁCH ĐƠN HÀNG")
            </a>
        </div>

        <div class="order-main-grid" style="display: grid; grid-template-columns: 1.8fr 1fr; gap: 20px; align-items: start;">
            
            <div class="left-col">
                @if (isConfirm)
                {
                    <!-- XÁC NHẬN MODE MATCHING NEW THEME -->
                    <div style="background: #fff; border-radius: 30px; padding: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); margin-bottom: 30px; border: 1px solid #e5e7eb;">
                        <h2 style="margin: 0 0 30px 0; font-weight: 900; color: #EA580C; font-size: 1.8rem;">THÔNG TIN NHẬN HÀNG</h2>
                        <form asp-action="ProcessCheckout" method="post">
                            <input type="hidden" name="OrderId" value="@Model.OrderId" />
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px;">
                                <div>
                                    <label style="display: block; font-weight: 700; color: #64748b; margin-bottom: 8px; font-size: 0.9rem;">Số điện thoại khách hàng *</label>
                                    <input type="text" name="PhoneNumber" value="@(string.IsNullOrEmpty(Model.PhoneNumber) ? Model.User?.Phone : Model.PhoneNumber)" required 
                                           pattern="[0-9]*" inputmode="numeric" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                                           style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #23150D; font-weight: 600;"
                                           placeholder="Nhập số điện thoại (10-11 số)">
                                </div>
                                <div>
                                    <label style="display: block; font-weight: 700; color: #64748b; margin-bottom: 8px; font-size: 0.9rem;">Hình thức thanh toán *</label>
                                    <select name="PaymentMethod" style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #23150D; font-weight: 700;">
                                        <option value="1">Tiền mặt (COD)</option>
                                        <option value="2">Chuyển khoản / Ví điện tử</option>
                                    </select>
                                </div>
                            </div>
                            <div style="margin-bottom: 25px;">
                                <label style="display: block; font-weight: 700; color: #64748b; margin-bottom: 8px; font-size: 0.9rem;">Địa chỉ giao hàng chi tiết *</label>
                                <textarea name="ShippingAddress" rows="3" required maxlength="200" 
                                          style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #23150D; font-weight: 600;"
                                          placeholder="Nhập địa chỉ giao hàng cụ thể...">@(string.IsNullOrEmpty(Model.ShippingAddress) ? Model.User?.Address : Model.ShippingAddress)</textarea>
                            </div>

                            <!-- ====== VOUCHER SECTION NÂNG CẤP ====== -->
                            <div style="margin-bottom: 25px;">
                                <label style="display: block; font-weight: 800; color: #374151; margin-bottom: 10px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-ticket" style="color: #d97706;"></i> Mã giảm giá
                                </label>
                                
                                @if (Model.Voucher != null)
                                {
                                    <!-- Đã áp dụng -->
                                    <div style="display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: #ecfdf5; border: 1px solid #6ee7b7; border-radius: 12px;">
                                        <i class="fa-solid fa-circle-check" style="color: #10b981; font-size: 1.2rem;"></i>
                                        <div style="flex: 1;">
                                            <div style="font-weight: 900; color: #065f46; font-family: monospace; font-size: 1rem;">@Model.Voucher.Code</div>
                                            <div style="font-size: 0.8rem; color: #047857; font-weight: 600;">@Model.Voucher.Name</div>
                                        </div>
                                        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 6px;">
                                            <div style="font-weight: 900; color: #10b981; font-size: 0.9rem; white-space: nowrap;">- @((Model.DiscountAmount).ToString("N0"))đ</div>
                                            <button type="button" onclick="removeOrderVoucher()" 
                                                    style="padding: 4px 10px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; border-radius: 8px; font-size: 0.75rem; font-weight: 800; cursor: pointer; white-space: nowrap; transition: 0.2s;"
                                                    onmouseover="this.style.background='#fecaca'" onmouseout="this.style.background='#fee2e2'">
                                                <i class="fa-solid fa-xmark"></i> Đổi / Bỏ
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <!-- Chưa áp dụng -->
                                    <div style="display: flex; gap: 10px; align-items: stretch;">
                                        <input type="text" id="orderVoucherCode" placeholder="Nhập hoặc chọn mã..."
                                               style="flex: 1; padding: 13px 16px; border-radius: 10px; border: 1.5px solid #e5e7eb; background: #f9fafb; color: #1f2937; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; outline: none; transition: 0.2s;"
                                               onfocus="this.style.borderColor='#d97706'; this.style.boxShadow='0 0 0 3px rgba(217,119,6,0.12)'"
                                               onblur="this.style.borderColor='#e5e7eb'; this.style.boxShadow='none'">
                                        <button type="button" onclick="applyOrderVoucher()" id="btnApplyVoucher"
                                                style="padding: 0 18px; background: #d97706; color: white; border: none; border-radius: 10px; font-weight: 800; font-size: 0.88rem; cursor: pointer; transition: 0.2s; white-space: nowrap;"
                                                onmouseover="this.style.background='#b45309'" onmouseout="this.style.background='#d97706'">
                                            Áp dụng
                                        </button>
                                        <button type="button" onclick="openVoucherModal()" id="btnChooseVoucher"
                                                title="Chọn từ kho voucher"
                                                style="padding: 0 14px; background: #fffbeb; color: #d97706; border: 1.5px solid #d97706; border-radius: 10px; font-weight: 800; font-size: 0.88rem; cursor: pointer; transition: 0.2s; white-space: nowrap;"
                                                onmouseover="this.style.background='#fef3c7'" onmouseout="this.style.background='#fffbeb'">
                                            <i class="fa-solid fa-layer-group"></i> Kho
                                        </button>
                                    </div>
                                    <p id="voucherMessage" style="margin: 7px 0 0 0; font-size: 0.82rem; font-weight: 700; display: none;"></p>
                                }
                            </div>

                            <button type="submit" style="width: 100%; padding: 20px; background: #EA580C; color: white; border: none; border-radius: 15px; font-weight: 950; font-size: 1.2rem; cursor: pointer; box-shadow: 0 10px 20px rgba(234, 88, 12, 0.2);">XÁC NHẬN ĐẶT HÀNG</button>
                        </form>
                    </div>
                }
                else
                {
                    <!-- MASTER INTEGRATED TRACKING CARD (Matching Reference Image) -->
                    <div style="background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c); padding: 3px; border-radius: 40px; margin-bottom: 35px; position: relative; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.35);">
                        
                        @* GLOBAL ANIMATED SHIMMER EFFECT *@
                        <div class="banner-shimmer"></div>
                        <style>
                            .banner-shimmer {
                                position: absolute; top: 0; left: -150%; width: 300%; height: 100%;
                                background: linear-gradient(115deg, transparent 45%, rgba(255, 255, 255, 0.25) 50%, transparent 55%);
                                animation: shimmer_sweep 7s infinite ease-in-out; pointer-events: none; z-index: 5;
                            }
                            @@keyframes shimmer_sweep { 0% { left: -150%; } 50% { left: 50%; } 100% { left: -150%; } }

                            /* Restoring the logic for the running progress bar pulse */
                            .active-laser {
                                position: absolute; top: 0; left: -50%; width: 100%; height: 100%;
                                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
                                animation: laser_move 2s infinite linear;
                            }
                            @@keyframes laser_move { 0% { left: -100%; } 100% { left: 100%; } }
                        </style>

                        @* INTERNAL CONTENT CONTAINER with Seamless Vertical Gradient (Tighter amber top) *@
                        <div style="background: linear-gradient(to bottom, #d97706, #B45309 80px, #ffffff 160px); border-radius: 38px; overflow: hidden; position: relative; z-index: 1;">
                            
                            <!-- CONTENT GRID -->
                            <div style="position: relative; z-index: 3; padding: 25px 45px 45px 45px;">
                                
                                <!-- TIME SECTION (More compact) -->
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                                    <div style="display: flex; align-items: center; gap: 20px;">
                                        <img src="/Images/Redesign/Gemini_Generated_Image_tnlfl3tnlfl3tnlf-Photoroom.png" style="width: 80px; height: 80px; object-fit: contain; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.2));" />
                                        <div>
                                            <span style="font-size: 11px; font-weight: 1000; color: rgba(255,255,255,0.9); text-transform: uppercase; letter-spacing: 1.5px;">Thời gian giao hàng dự kiến</span>
                                            <h2 style="margin: 0; font-size: 3.2rem; font-weight: 1000; color: #fff; letter-spacing: -2px; line-height: 1; text-shadow: 0 10px 20px rgba(0,0,0,0.2);">@timeRange</h2>
                                        </div>
                                    </div>
                                    <div style="opacity: 0.2;">
                                         <i class="fa-solid fa-truck-fast" style="font-size: 60px; color: #fff;"></i>
                                    </div>
                                </div>

                                <!-- TRACKING STATUS SECTION -->
                                <div style="position: relative;">
                                    <h4 style="margin: 0 0 8px 0; color: #23150D; font-weight: 1000; font-size: 1.5rem; display: flex; align-items: center; gap: 12px; text-transform: uppercase;">
                                        <i class="fa-solid @statusIcon" style="color: #EA580C;"></i> @statusText
                                    </h4>
                                    <p style="margin: 0 0 45px 0; color: #64748b; font-weight: 700; font-size: 0.9rem;">@statusDesc</p>

                                    <!-- PROGRESS FLOW -->
                                    <div style="position: relative; width: 94%; margin: 80px auto 100px auto;">
                                        <div style="height: 6px; background: rgba(0,0,0,0.05); width: 100%; border-radius: 10px; position: relative;">
                                            <div style="position: absolute; left: 0; top: 0; height: 100%; width: @progressWidth; background: #6B3E26; border-radius: 10px; transition: 1s ease; z-index: 2;"></div>
                                            @if (Model.OrderStatus >= 1 && Model.OrderStatus < 4) {
                                                string activeLeft = Model.OrderStatus switch { 1=>"0%", 2=>"33.33%", 3=>"66.66%", _=>"0%" };
                                                <div style="position: absolute; left: @activeLeft; top: 0; height: 100%; width: 33.33%; background: rgba(107, 62, 38, 0.1); overflow: hidden; z-index: 1;">
                                                    <div class="active-laser"></div>
                                                </div>
                                            }
                                        </div>
                                        <!-- PROGRESS FLOW Milestones -->
                                        <div style="display: flex; justify-content: space-between; position: absolute; top: -7px; width: 100%; z-index: 10;">
                                            @for (int i = 1; i <= 4; i++) {
                                                var reached = Model.OrderStatus >= i && Model.OrderStatus != 5;
                                                var active = Model.OrderStatus == i;
                                                var isCancelled = Model.OrderStatus == 5;
                                                var nIcon = i switch { 1=>"fa-file-invoice", 2=>"fa-mug-hot", 3=>"fa-motorcycle", 4=>"fa-house", _=>"" };
                                                
                                                // Milestone Label Logic
                                                string label = i switch { 1=>"Đã xác nhận", 2=>"Đang chuẩn bị", 3=>"Đang giao", 4=>"Đã giao", _=>"" };
                                                if (i == 1 && isCancelled) label = "ĐÃ HỦY";

                                                <div style="width: 20px; height: 20px; position: relative; display: flex; justify-content: center; align-items: center;">
                                                    <div style="position: absolute; top: -45px; width: 40px; text-align: center;">
                                                        <i class="fa-solid @nIcon" style="font-size: 14px; color: @(reached || (i==1 && isCancelled) ? (isCancelled ? "#ef4444" : "#6B3E26") : "#cbd5e1");"></i>
                                                    </div>
                                                    <div style="width: 20px; height: 20px; min-width: 20px; background: @(reached || (i==1 && isCancelled) ? (isCancelled ? "#ef4444" : "#6B3E26") : "#fff"); border: 4px solid @(reached || (i==1 && isCancelled) ? (isCancelled ? "#ef4444" : "#6B3E26") : "#E5E7EB"); border-radius: 50%; box-shadow: @(active ? "0 0 15px rgba(107, 62, 38, 0.4)" : "none");"></div>
                                                    <div style="position: absolute; top: 32px; width: 120px; text-align: center;">
                                                        <span style="display: block; font-size: 10px; font-weight: 1000; text-transform: uppercase; color: @(reached || (i==1 && isCancelled) ? (isCancelled ? "#ef4444" : "#23150D") : "#94a3b8"); letter-spacing: 0.5px;">
                                                            @label
                                                        </span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- BOTTOM SECTION: SHIPPER INFO & CANCEL BUTTON -->
                                    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 20px; margin-top: 10px;">
                                        @if (Model.OrderStatus != 5 && Model.OrderStatus != 4)
                                        {
                                            <!-- RANDOM SHIPPER INFO (Fake Data) -->
                                            <div style="display: flex; align-items: center; gap: 15px;">
                                                <div style="width: 45px; height: 45px; border-radius: 50%; overflow: hidden; border: 2px solid #EA580C; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                                                    <img src="https://i.pravatar.cc/150?u=@Model.OrderId" style="width: 100%; height: 100%; object-fit: cover;" />
                                                </div>
                                                <div>
                                                    <h6 style="margin: 0; color: #18181b; font-weight: 900; font-size: 13px;">Nguyễn Văn Tài (Shipper)</h6>
                                                    <div style="display: flex; align-items: center; gap: 8px;">
                                                        <span style="color: #16a34a; font-weight: 700; font-size: 11px;"><i class="fa-solid fa-phone"></i> 0987.xxx.234</span>
                                                        <span style="color: #f59e0b; font-weight: 900; font-size: 11px;"><i class="fa-solid fa-star"></i> 4.9</span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div style="color: #94a3b8; font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">
                                                @(Model.OrderStatus == 5 ? "ĐƠN HÀNG ĐÃ DỪNG" : "GIAO HÀNG THÀNH CÔNG")
                                            </div>
                                        }

                                        <!-- CANCEL BUTTON (Only if Pending) -->
                                        @if (Model.OrderStatus == 1 && !isConfirm)
                                        {
                                            <button onclick="cancelOrder(@Model.OrderId)" style="padding: 10px 20px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; border-radius: 12px; font-weight: 900; font-size: 12px; cursor: pointer; transition: 0.3s; text-transform: uppercase;"
                                                    onmouseover="this.style.background='#fecaca'" onmouseout="this.style.background='#fee2e2'">
                                                Hủy đơn hàng
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* Background Illustration - Shipper Image *@
                            <img src="/Images/Redesign/Gemini_Generated_Image_fo7jf1fo7jf1fo7j-Photoroom.png" 
                                 style="position: absolute; right: -40px; bottom: -30px; width: 550px; z-index: 2; pointer-events: none; opacity: 1; filter: drop-shadow(-20px 0 30px rgba(0,0,0,0.05));" />
                        </div>
                    </div>

                    <!-- 4. DETAILED ROUTE CARD (Cleaned up) -->
                    <div style="background: #fff; border-radius: 35px; padding: 35px 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; min-height: 280px; margin-bottom: 25px;">
                        <h4 style="margin: 0 0 20px 0; color: #23150D; font-weight: 1000; font-size: 1.3rem; text-transform: uppercase; display: flex; align-items: center; gap: 12px; letter-spacing: -0.5px;">
                            <i class="fa-solid fa-map-location-dot" style="color: #8B5E3C;"></i> LỘ TRÌNH CHI TIẾT
                        </h4>
                        
                        <div style="display: flex; flex-direction: column; gap: 0; position: relative;">
                            @* VERTICAL CONNECTING LINE (Dashed) *@
                            <div style="position: absolute; left: 15px; top: 35px; bottom: 35px; border-left: 2px dashed #e2e8f0; z-index: 1;"></div>

                            @* POINT 1: PICKUP *@
                            <div style="display: flex; align-items: start; gap: 20px; padding-bottom: 30px; position: relative; z-index: 2;">
                                <div style="width: 32px; height: 32px; min-width: 32px; background: #fff; border: 2px solid #3b82f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 10px rgba(59, 130, 246, 0.2);">
                                    <div style="width: 12px; height: 12px; background: #3b82f6; border-radius: 50%;"></div>
                                </div>
                                <div style="flex: 1;">
                                    <h5 style="margin: 0; font-size: 15px; font-weight: 1000; color: #18181b;">Bread & Brew - Quán cà phê cao cấp</h5>
                                    <p style="margin: 4px 0 0 0; color: #71717a; font-size: 13px; font-weight: 700;">300 Đống Đa, P. Hải Châu, TP. Đà Nẵng</p>
                                </div>
                            </div>

                            @* POINT 2: CURRENT STATUS (GREEN) *@
                            <div style="display: flex; align-items: start; gap: 20px; padding-bottom: 30px; position: relative; z-index: 2;">
                                <div style="width: 32px; height: 32px; min-width: 32px; background: #fff; border: 2px solid #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative;">
                                    <div style="width: 12px; height: 12px; background: #22c55e; border-radius: 50%;"></div>
                                    <div class="status-dot-pulse"></div>
                                </div>
                                <style>
                                    .status-dot-pulse {
                                        position: absolute; width: 100%; height: 100%; border-radius: 50%;
                                        border: 2px solid #22c55e; opacity: 0; animation: pulse_live 2s infinite;
                                    }
                                    @@keyframes pulse_live { 0% { transform: scale(1); opacity: 0.6; } 100% { transform: scale(1.6); opacity: 0; } }
                                </style>
                                <div style="flex: 1;">
                                    <h5 style="margin: 0; font-size: 15px; font-weight: 1000; color: #22c55e; text-transform: uppercase;">@(Model.OrderStatus == 5 ? "ĐÃ HỦY ĐƠN" : statusText)</h5>
                                    <p style="margin: 4px 0 0 0; color: #71717a; font-size: 12px; font-weight: 700;">@(Model.OrderStatus == 5 ? "Rất tiếc đơn hàng đã bị hủy" : "Trạng thái đơn hàng hiện tại")</p>
                                </div>
                            </div>

                            @* POINT 3: DELIVERY *@
                            <div style="display: flex; align-items: center; gap: 20px; padding-top: 10px; padding-bottom: 20px; position: relative; z-index: 2;">
                                <div style="width: 32px; height: 32px; min-width: 32px; background: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1.5px solid #ef4444;">
                                    <div style="width: 14px; height: 14px; background: #ef4444; border-radius: 50%; border: 2.5px solid #fff;"></div>
                                </div>
                                <div style="flex: 1; display: flex; justify-content: space-between; align-items: center;">
                                    <h5 style="margin: 0; font-size: 15px; font-weight: 1000; color: #18181b;">Địa điểm giao hàng</h5>
                                    <i class="fa-solid fa-chevron-right" style="color: #71717a; font-size: 12px;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- RIGHT COL: WHITE CARDS -->
            <div class="right-col">
                <!-- 1. ORDER INFO (INSET INTERNAL FRAME STYLE - 100% MATCH IMAGE 6) -->
                <div style="background: #ffffff; border-radius: 35px; padding: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); margin-bottom: 30px; border: 1px solid #f1f5f9;">
                    @* THE "INTERNAL FRAME" REQUESTED *@
                    <div style="border: 1.5px solid #e7e5e4; border-radius: 28px; padding: 22px 28px; background: #fff;">
                        @* HEADER *@
                        <h4 style="margin: 0 0 10px 0; color: #18181b; font-weight: 1000; font-size: 1.15rem; display: flex; align-items: center; gap: 10px; text-transform: uppercase; letter-spacing: -0.5px;">
                            <i class="fa-solid fa-file-invoice" style="color: #8b5e3c; font-size: 1rem;"></i> THÔNG TIN ĐƠN
                        </h4>
                        
                        @* ORDER META - SUPER COMPACT *@
                        <div style="display: flex; flex-direction: column; gap: 4px; font-size: 13.5px; margin-bottom: 15px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #71717a; font-weight: 700;">Mã đơn hàng:</span>
                                <span style="color: #18181b; font-weight: 900;">#@Model.OrderId</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #71717a; font-weight: 700;">Ngày đặt:</span>
                                <span style="color: #18181b; font-weight: 900;">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #71717a; font-weight: 700;">Thanh toán:</span>
                                <span style="color: #18181b; font-weight: 900;">@(Model.PaymentMethod == 1 ? "Tiền mặt (COD)" : "Chuyển khoản / Momo")</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #71717a; font-weight: 700;">Voucher:</span>
                                <span style="color: @(Model.Voucher != null ? "#EA580C" : "#18181b"); font-weight: 900;">@(Model.Voucher?.Code ?? "Không có")</span>
                            </div>
                        </div>

                        @* DASHED LINE FROM IMAGE 6 *@
                        <div style="border-top: 1.2px dashed #B58E6D; margin-bottom: 15px; opacity: 0.7;"></div>

                        @* PRODUCT LIST - FLAT *@
                        <div style="margin-bottom: 15px;">
                            @foreach (var item in Model.OrderDetails)
                            {
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #f9fafb;">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 50px; height: 50px; border-radius: 12px; overflow: hidden; border: 1px solid #f1f5f9; flex-shrink: 0;">
                                            <img src="@(string.IsNullOrEmpty(item.Product?.Image) ? "/Images/default.png" : (item.Product.Image.Contains("http") ? item.Product.Image : $"/Images/{item.Product.Image}"))" style="width: 100%; height: 100%; object-fit: cover;" />
                                        </div>
                                        <div style="display: flex; flex-direction: column; gap: 2px;">
                                            <span style="color: #18181b; font-weight: 1000; font-size: 14px; display: block; line-height: 1.2;">@(item.Product?.ProductName)</span>
                                            <span style="display: inline-block; background: #f1f5f9; color: #64748b; font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 6px; width: fit-content;">x @item.Quantity</span>
                                        </div>
                                    </div>
                                    <span style="color: #18181b; font-weight: 1000; font-size: 14px; background: #fffbeb; padding: 4px 10px; border-radius: 10px; color: #b45309;">@((item.Price * item.Quantity).ToString("N0"))đ</span>
                                </div>
                            }
                        </div>

                        @* TOTAL SUMMARY *@
                        <div style="text-align: right; border-top: 1px solid #f9fafb; padding-top: 10px;">
                            <span style="color: #71717a; font-size: 9.5px; font-weight: 1000; text-transform: uppercase;">TỔNG CỘNG</span>
                            <h3 style="margin: 0; color: #EA580C; font-size: 1.95rem; font-weight: 1000; letter-spacing: -1.2px;">@Model.FinalAmount.ToString("N0")đ</h3>
                        </div>
                    </div>
                </div>

                @* STYLES: AWARD/DIPLOMA FRAME WITH CONCAVE CORNERS *@
                <style>
                    .for-you-award-outer {
                        background:
                            radial-gradient(circle at 0 0, transparent 22px, #B8834F 22px) 0 0 / 51% 51% no-repeat,
                            radial-gradient(circle at 100% 0, transparent 22px, #B8834F 22px) 100% 0 / 51% 51% no-repeat,
                            radial-gradient(circle at 0 100%, transparent 22px, #B8834F 22px) 0 100% / 51% 51% no-repeat,
                            radial-gradient(circle at 100% 100%, transparent 22px, #B8834F 22px) 100% 100% / 51% 51% no-repeat;
                        padding: 7px;
                        margin-bottom: 20px;
                        box-shadow: 0 12px 35px rgba(0,0,0,0.25);
                    }
                    .for-you-award-inner {
                        background:
                            radial-gradient(circle at 0 0, transparent 16px, #FFFBF7 16px) 0 0 / 51% 51% no-repeat,
                            radial-gradient(circle at 100% 0, transparent 16px, #FFFBF7 16px) 100% 0 / 51% 51% no-repeat,
                            radial-gradient(circle at 0 100%, transparent 16px, #FFFBF7 16px) 0 100% / 51% 51% no-repeat,
                            radial-gradient(circle at 100% 100%, transparent 16px, #FFFBF7 16px) 100% 100% / 51% 51% no-repeat;
                        padding: 18px 22px;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        min-height: 130px;
                        position: relative;
                    }
                    .review-pill-btn {
                        display: inline-block;
                        background: linear-gradient(90deg, #EA580C 0%, #F59E0B 100%);
                        color: #fff;
                        padding: 9px 32px;
                        border-radius: 50px;
                        text-decoration: none;
                        font-weight: 900;
                        font-size: 13px;
                        box-shadow: 0 6px 20px rgba(234, 88, 12, 0.45), 0 2px 8px rgba(245, 158, 11, 0.3);
                        letter-spacing: 0.3px;
                        transition: transform 0.2s ease, box-shadow 0.2s ease;
                    }
                    .review-pill-btn:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 10px 28px rgba(234, 88, 12, 0.55);
                        color: #fff;
                    }
                </style>

                @if (!isConfirm && Model.OrderStatus == 4)
                {
                    <!-- 2. FOR YOU (AWARD/DIPLOMA FRAME - CONCAVE CORNERS) -->
                    <div class="for-you-award-outer">
                        <div class="for-you-award-inner">
                            @* LEFT: CONTENT *@
                            <div style="flex: 1.2; z-index: 3;">
                                <h4 style="margin: 0 0 6px 0; color: #18181b; font-weight: 1000; font-size: 1.15rem; letter-spacing: -0.5px;">Dành cho bạn</h4>
                                <p style="margin: 0 0 15px 0; color: #71717a; font-size: 11.5px; line-height: 1.45; font-weight: 700; max-width: 230px;">
                                    Cảm ơn bạn đã lựa chọn Bread & Brew. Hãy chia sẻ cảm nhận của bạn sau khi nhận món nhé!
                                </p>
                                <a href="#" class="review-pill-btn" onclick="openReviewModal(); return false;">Đánh giá</a>
                            </div>

                            @* RIGHT: CHARACTER ILLUSTRATION WITH FLOATING SHADOW *@
                            <div style="width: 162px; margin-right: -18px; align-self: flex-end; margin-bottom: -18px;">
                                <img src="/Images/Redesign/Gemini_Generated_Image_qikjwpqikjwpqikj-Photoroom.png"
                                     style="width: 100%; height: auto; display: block; transform: scaleX(-1);
                                            filter: drop-shadow(0 10px 22px rgba(0,0,0,0.22));" />
                            </div>

                            @* HEARTS DECO *@
                            <div style="position: absolute; right: 148px; top: 38%; opacity: 0.9; transform: rotate(-10deg); filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15));">
                                <i class="fa-solid fa-heart" style="color: #B58E6D; font-size: 14px;"></i>
                            </div>
                            <div style="position: absolute; right: 28px; top: 32%; opacity: 0.9; transform: rotate(10deg); filter: drop-shadow(0 2px 4px rgba(0,0,0,0.12));">
                                <i class="fa-solid fa-heart" style="color: #B58E6D; font-size: 11px;"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ====== REVIEW POPUP MODAL ====== -->
<div id="reviewModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.6); backdrop-filter:blur(8px); display:none; align-items:center; justify-content:center; padding:20px;">
    <div id="reviewCard" style="background:#fff; border-radius:28px; width:100%; max-width:420px; box-shadow:0 30px 80px rgba(0,0,0,0.35); overflow:hidden; transform:translateY(30px); opacity:0; transition:all 0.35s cubic-bezier(0.34,1.56,0.64,1);">

        <!-- MODAL HEADER -->
        <div style="background:linear-gradient(135deg,#B45309,#78350F); padding:20px 25px 15px; position:relative; text-align:center;">
            <button onclick="closeReviewModal()" style="position:absolute; left:18px; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.15); border:none; color:#fff; width:34px; height:34px; border-radius:50%; cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center;">
                <i class="fa-solid fa-arrow-left" style="font-size:14px;"></i>
            </button>
            <span style="color:#fff; font-weight:1000; font-size:1.15rem; letter-spacing:-0.5px;">Đánh giá</span>
        </div>

        <!-- LOGO + BRAND -->
        <div style="background:linear-gradient(135deg,#B45309,#78350F); padding:0 0 30px; display:flex; flex-direction:column; align-items:center;">
            <div style="width:90px; height:90px; border-radius:50%; background:#fff; border:4px solid rgba(255,255,255,0.3); overflow:hidden; box-shadow:0 8px 25px rgba(0,0,0,0.25); margin-bottom:12px;">
                <img src="/Images/Redesign/brand_wood_logo.jpg" style="width:100%; height:100%; object-fit:cover;" />
            </div>
            <h3 style="margin:0; color:#fff; font-weight:1000; font-size:1.1rem; letter-spacing:-0.3px;">Tiệm Cà Phê &amp; Bánh Ngọt</h3>
            <p style="margin:4px 0 0; color:rgba(255,255,255,0.7); font-size:12px; font-weight:700;">Bread &amp; Brew</p>
        </div>

        <!-- FORM CONTENT -->
        <div style="padding:28px 28px 24px;">

            <!-- STAR RATING -->
            <p style="margin:0 0 12px; color:#23150D; font-weight:900; font-size:14px;">Bạn thấy hương vị thế nào?</p>
            <div id="starRating" style="display:flex; gap:10px; margin-bottom:28px;">
                @for (int s = 1; s <= 5; s++)
                {
                    <i class="fa-star star-btn" data-val="@s"
                       style="font-size:36px; color:#e2e8f0; cursor:pointer; transition:color 0.15s ease, transform 0.15s ease;"
                       onmouseover="hoverStars(@s)" onmouseout="resetStars()" onclick="selectStars(@s)"></i>
                }
            </div>

            <!-- COMMENT (OPTIONAL) -->
            <label style="display:block; color:#23150D; font-weight:900; font-size:14px; margin-bottom:8px;">
                Nhận xét <span style="color:#94a3b8; font-weight:600; font-size:12px;">(không bắt buộc)</span>
            </label>
            <textarea id="reviewComment" rows="4" placeholder="Chia sẻ cảm nhận của bạn..."
                style="width:100%; padding:14px 16px; border:1.5px solid #e7e5e4; border-radius:14px; font-size:13.5px; color:#23150D; font-family:'Inter',sans-serif; resize:none; outline:none; transition:border-color 0.2s; box-sizing:border-box;"
                onfocus="this.style.borderColor='#EA580C'" onblur="this.style.borderColor='#e7e5e4'"></textarea>

            <!-- HIDDEN: SELECTED RATING -->
            <input type="hidden" id="selectedRating" value="0" />

            <!-- SUBMIT BUTTON -->
            <button onclick="submitReview(@Model.OrderId)" style="width:100%; margin-top:20px; padding:15px; background:linear-gradient(90deg,#EA580C,#F59E0B); color:#fff; border:none; border-radius:50px; font-size:15px; font-weight:1000; cursor:pointer; box-shadow:0 8px 25px rgba(234,88,12,0.4); transition:transform 0.2s ease,box-shadow 0.2s ease;"
                onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 12px 30px rgba(234,88,12,0.5)'"
                onmouseout="this.style.transform=''; this.style.boxShadow='0 8px 25px rgba(234,88,12,0.4)'">
                Gửi đánh giá
            </button>
        </div>
    </div>
</div>

<style>
    .star-btn { font-family: 'Font Awesome 6 Free'; font-weight: 900; }
    #reviewModal.active { display: flex !important; }
    #reviewModal.active #reviewCard { transform: translateY(0); opacity: 1; }
</style>

<!-- ====== VOUCHER PICKER MODAL ====== -->
<div id="voucherPickerModal" style="display:none; position:fixed; inset:0; z-index:10000; background:rgba(0,0,0,0.55); backdrop-filter:blur(6px); align-items:center; justify-content:center; padding:20px;">
    <div id="voucherPickerSheet" style="background:#fff; border-radius:28px; width:100%; max-width:600px; max-height:85vh; display:flex; flex-direction:column; overflow:hidden; transform:scale(0.9); opacity:0; transition:0.3s cubic-bezier(0.34,1.56,0.64,1);">
        
        <!-- HEADER -->
        <div style="padding: 20px 24px 0; flex-shrink: 0;">
            <div style="width:40px; height:4px; background:#e5e7eb; border-radius:10px; margin: 0 auto 16px;"></div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                <h3 style="margin:0; font-size:1.1rem; font-weight:900; color:#1f2937;"><i class="fa-solid fa-ticket-simple" style="color:#d97706; margin-right:8px;"></i>Chọn Mã Giảm Giá</h3>
                <button onclick="closeVoucherModal()" style="background:#f3f4f6; border:none; width:34px; height:34px; border-radius:50%; cursor:pointer; font-size:16px; color:#6b7280; display:flex; align-items:center; justify-content:center;"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <!-- TABS -->
            <div style="display:flex; gap:0; background:#f3f4f6; border-radius:12px; padding:4px;">
                <button id="tabSaved" onclick="switchTab('saved')" style="flex:1; padding:9px; border:none; border-radius:9px; font-weight:800; font-size:0.85rem; cursor:pointer; background:#fff; color:#d97706; box-shadow:0 1px 4px rgba(0,0,0,0.08); transition:0.2s;">
                    <i class="fa-solid fa-bookmark"></i> Kho của tôi
                </button>
                <button id="tabAll" onclick="switchTab('all')" style="flex:1; padding:9px; border:none; border-radius:9px; font-weight:800; font-size:0.85rem; cursor:pointer; background:transparent; color:#9ca3af; transition:0.2s;">
                    <i class="fa-solid fa-tags"></i> Tất cả ưu đãi
                </button>
            </div>
        </div>

        <!-- VOUCHER LIST (scrollable) -->
        <div id="voucherListContainer" style="flex:1; overflow-y:auto; padding:16px 24px 24px;">
            <div id="voucherLoadingState" style="text-align:center; padding:40px; color:#9ca3af;">
                <i class="fa-solid fa-spinner fa-spin" style="font-size:2rem;"></i>
                <p style="margin-top:10px; font-weight:700;">Đang tải...</p>
            </div>
            <div id="savedVoucherList" style="display:none;"></div>
            <div id="allVoucherList" style="display:none;"></div>
        </div>
    </div>
</div>

<script>
    var _selectedRating = 0;

    // ============================================================
    // VOUCHER PICKER LOGIC
    // ============================================================
    var _allVouchers = [];
    var _currentTab = 'saved';

    function openVoucherModal() {
        var modal = document.getElementById('voucherPickerModal');
        modal.style.display = 'flex';
        setTimeout(() => {
            var sheet = document.getElementById('voucherPickerSheet');
            sheet.style.transform = 'scale(1)';
            sheet.style.opacity = '1';
        }, 10);
        document.body.style.overflow = 'hidden';
        loadVouchers();
    }

    function closeVoucherModal() {
        var sheet = document.getElementById('voucherPickerSheet');
        sheet.style.transform = 'scale(0.9)';
        sheet.style.opacity = '0';
        setTimeout(() => {
            document.getElementById('voucherPickerModal').style.display = 'none';
            document.body.style.overflow = '';
        }, 300);
    }

    document.getElementById('voucherPickerModal').addEventListener('click', function(e) {
        if (e.target === this) closeVoucherModal();
    });

    function loadVouchers() {
        document.getElementById('voucherLoadingState').style.display = 'block';
        document.getElementById('savedVoucherList').style.display = 'none';
        document.getElementById('allVoucherList').style.display = 'none';

        fetch('/Cart/GetVouchersForOrder?orderId=@Model.OrderId')
            .then(res => res.json())
            .then(data => {
                document.getElementById('voucherLoadingState').style.display = 'none';
                _allVouchers = data.vouchers || [];
                renderTab(_currentTab);
            });
    }

    function switchTab(tab) {
        _currentTab = tab;
        var tabSaved = document.getElementById('tabSaved');
        var tabAll = document.getElementById('tabAll');

        if (tab === 'saved') {
            tabSaved.style.background = '#fff';
            tabSaved.style.color = '#d97706';
            tabSaved.style.boxShadow = '0 1px 4px rgba(0,0,0,0.08)';
            tabAll.style.background = 'transparent';
            tabAll.style.color = '#9ca3af';
            tabAll.style.boxShadow = 'none';
        } else {
            tabAll.style.background = '#fff';
            tabAll.style.color = '#d97706';
            tabAll.style.boxShadow = '0 1px 4px rgba(0,0,0,0.08)';
            tabSaved.style.background = 'transparent';
            tabSaved.style.color = '#9ca3af';
            tabSaved.style.boxShadow = 'none';
        }
        renderTab(tab);
    }

    function renderVoucherCard(v, tabContext) {
        var discountText = v.discountType === 1 ? v.discountValue + '%' : (v.discountValue/1000).toFixed(0) + 'K';
        var canUse = v.canUse;
        var isApplied = v.isApplied;
        var isSaved = v.isSaved;

        // Badge trạng thái
        var badgeHtml = '';
        if (isApplied) badgeHtml = '<span style="background:#dcfce7; color:#15803d; font-size:10px; font-weight:900; padding:2px 8px; border-radius:20px;">✓ Đang dùng</span>';
        else if (isSaved) badgeHtml = '<span style="background:#fef3c7; color:#d97706; font-size:10px; font-weight:900; padding:2px 8px; border-radius:20px;"><i class="fa-solid fa-bookmark"></i> Đã lưu</span>';

        // Logic click & nút hành động theo tab
        var clickHandler = '';
        var actionBtn = '';
        var cursor = 'default';
        var borderColor = isApplied ? '#6ee7b7' : '#e5e7eb';
        var cardOpacity = '1';

        if (isApplied) {
            // Đang được dùng: không làm gì
            cursor = 'default';
        } else if (isSaved && canUse) {
            // Đã lưu + đủ điều kiện: click để áp dụng luôn
            clickHandler = `onclick="selectVoucher('${v.code}')"`;
            cursor = 'pointer';
            borderColor = '#e5e7eb';
        } else if (isSaved && !canUse) {
            // Đã lưu nhưng chưa đủ điều kiện: xám, không click
            cardOpacity = '0.6';
            cursor = 'default';
        } else {
            // Chưa lưu (tab 'all'): chặn click, chỉ hiện nút Lưu
            cardOpacity = canUse ? '1' : '0.6';
            cursor = 'default';
            var saveLabel = '<i class="fa-solid fa-bookmark"></i> Lưu';
            actionBtn = `<button onclick="saveVoucherFromPopup(${v.voucherId}, this)" 
                            style="align-self:center; padding:7px 14px; background:#d97706; color:#fff; border:none; border-radius:8px; font-size:0.78rem; font-weight:800; cursor:pointer; white-space:nowrap; transition:0.2s; flex-shrink:0;"
                            onmouseover="this.style.background='#b45309'" onmouseout="this.style.background='#d97706'">${saveLabel}</button>`;
        }

        var cantUseNote = !canUse ? `<div style="font-size:11px; color:#f59e0b; font-weight:700; margin-top:4px;"><i class="fa-solid fa-circle-exclamation"></i> Cần đơn tối thiểu ${(v.minOrderValue/1000).toFixed(0)}k</div>` : '';

        var hoverAttrs = (cursor === 'pointer') ?
            `onmouseover="this.style.borderColor='#d97706'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.08)'"
             onmouseout="this.style.borderColor='${borderColor}'; this.style.transform='none'; this.style.boxShadow='none'"` : '';

        return `
            <div ${clickHandler} ${hoverAttrs} style="display:flex; gap:0; border:1.5px solid ${borderColor}; border-radius:14px; overflow:hidden; margin-bottom:10px; cursor:${cursor}; background:#fff; opacity:${cardOpacity}; transition:0.2s;">
                <!-- LEFT: discount -->
                <div style="background: linear-gradient(135deg, #d97706, #b45309); width:82px; min-width:82px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:14px 6px; position:relative;">
                    <div style="position:absolute; right:-10px; top:50%; transform:translateY(-50%); width:20px; height:20px; background:#fff; border-radius:50%; z-index:2;"></div>
                    <div style="font-size:0.55rem; font-weight:900; color:rgba(255,255,255,0.85); text-transform:uppercase; letter-spacing:1px;">Giảm</div>
                    <div style="font-size:1.5rem; font-weight:1000; color:#fff; line-height:1.1;">${discountText}</div>
                </div>
                <!-- RIGHT: info -->
                <div style="flex:1; padding:12px 14px; display:flex; align-items:center; gap:10px;">
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:6px; margin-bottom:3px; flex-wrap:wrap;">
                            <span style="font-weight:900; color:#1f2937; font-size:0.88rem;">${v.name || v.code}</span>
                            ${badgeHtml}
                        </div>
                        <div style="font-family:monospace; font-weight:900; color:#d97706; font-size:0.78rem; letter-spacing:1px;">${v.code}</div>
                        <div style="font-size:10px; color:#6b7280; font-weight:700; margin-top:2px;">HSD: ${v.endDate}</div>
                        ${cantUseNote}
                    </div>
                    ${actionBtn}
                </div>
            </div>`;
    }

    function renderTab(tab) {
        var savedEl = document.getElementById('savedVoucherList');
        var allEl = document.getElementById('allVoucherList');
        var savedVouchers = _allVouchers.filter(v => v.isSaved);
        var allVouchers = _allVouchers;

        if (tab === 'saved') {
            savedEl.style.display = 'block';
            allEl.style.display = 'none';
            savedEl.innerHTML = savedVouchers.length > 0
                ? savedVouchers.map(v => renderVoucherCard(v, 'saved')).join('')
                : '<div style="text-align:center; padding:40px; color:#9ca3af;"><i class="fa-solid fa-ticket-simple" style="font-size:2.5rem; opacity:0.2; margin-bottom:12px; display:block;"></i><p style="font-weight:700;">Kho trống! Lưu voucher từ trang <a href="/Home/Voucher" style="color:#d97706;">Trung tâm Voucher</a> nhé.</p></div>';
        } else {
            allEl.style.display = 'block';
            savedEl.style.display = 'none';
            allEl.innerHTML = allVouchers.length > 0
                ? allVouchers.map(v => renderVoucherCard(v, 'all')).join('')
                : '<div style="text-align:center; padding:40px; color:#9ca3af;"><p style="font-weight:700;">Hiện không có voucher nào.</p></div>';
        }
    }

    function saveVoucherFromPopup(voucherId, btn) {
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        btn.style.pointerEvents = 'none';

        fetch(`/Home/SaveVoucherToDb?voucherId=${voucherId}`, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                btn.innerHTML = '<i class="fa-solid fa-check"></i> Đã lưu';
                btn.style.background = '#6b7280';
                // Cập nhật trạng thái local và re-render
                var voucher = _allVouchers.find(v => v.voucherId === voucherId);
                if (voucher) voucher.isSaved = true;
                renderTab(_currentTab);
            } else {
                btn.innerHTML = '<i class="fa-solid fa-bookmark"></i> Lưu';
                btn.style.pointerEvents = 'auto';
            }
        });
    }

    function selectVoucher(code) {
        closeVoucherModal();
        doApplyVoucher(code);
    }

    function applyOrderVoucher() {
        var code = document.getElementById('orderVoucherCode')?.value.trim();
        if (!code) {
            showVoucherMsg('Vui lòng nhập mã voucher!', false);
            return;
        }
        doApplyVoucher(code);
    }

    function doApplyVoucher(code) {
        var btn = document.getElementById('btnApplyVoucher');
        if (btn) { btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; btn.style.pointerEvents = 'none'; }

        fetch(`/Cart/ApplyVoucherToOrder?orderId=@Model.OrderId&code=${encodeURIComponent(code)}`, {
            method: 'GET',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showVoucherMsg('Áp dụng thành công! Đang cập nhật...', true);
                setTimeout(() => location.reload(), 1200);
            } else {
                if (btn) { btn.innerHTML = 'Áp dụng'; btn.style.pointerEvents = 'auto'; }
                showVoucherMsg(data.message, false);
            }
        })
        .catch(() => {
            if (btn) { btn.innerHTML = 'Áp dụng'; btn.style.pointerEvents = 'auto'; }
            showVoucherMsg('Có lỗi xảy ra, vui lòng thử lại!', false);
        });
    }

    function removeOrderVoucher() {
        Swal.fire({
            title: 'Bỏ mã giảm giá?',
            text: 'Bạn có chắc muốn bỏ mã đang áp dụng không?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Bỏ voucher',
            cancelButtonText: 'Giữ lại'
        }).then(result => {
            if (result.isConfirmed) {
                fetch('/Cart/RemoveVoucherFromOrder?orderId=@Model.OrderId', {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: 'Đã bỏ voucher!', toast: true, position: 'top-end', showConfirmButton: false, timer: 1500 })
                            .then(() => location.reload());
                    }
                });
            }
        });
    }

    function showVoucherMsg(text, success) {
        var msg = document.getElementById('voucherMessage');
        if (!msg) return;
        msg.style.display = 'block';
        msg.style.color = success ? '#16a34a' : '#ef4444';
        msg.innerText = text;
    }

    function openReviewModal() {
        var modal = document.getElementById('reviewModal');
        modal.style.display = 'flex';
        // force reflow then animate
        setTimeout(function() {
            var card = document.getElementById('reviewCard');
            card.style.transform = 'translateY(0)';
            card.style.opacity = '1';
        }, 10);
        document.body.style.overflow = 'hidden';
    }

    function closeReviewModal() {
        var card = document.getElementById('reviewCard');
        card.style.transform = 'translateY(30px)';
        card.style.opacity = '0';
        setTimeout(function() {
            document.getElementById('reviewModal').style.display = 'none';
            document.body.style.overflow = '';
        }, 350);
    }

    // Close on overlay click
    document.getElementById('reviewModal').addEventListener('click', function(e) {
        if (e.target === this) closeReviewModal();
    });

    function hoverStars(val) {
        document.querySelectorAll('.star-btn').forEach(function(s, i) {
            s.style.color = i < val ? '#F59E0B' : '#e2e8f0';
            s.style.transform = i < val ? 'scale(1.1)' : '';
            s.classList.toggle('fa-solid', i < val);
            s.classList.toggle('fa-regular', i >= val);
        });
    }

    function resetStars() {
        document.querySelectorAll('.star-btn').forEach(function(s, i) {
            s.style.color = i < _selectedRating ? '#EA580C' : '#e2e8f0';
            s.style.transform = '';
            s.classList.toggle('fa-solid', i < _selectedRating);
            s.classList.toggle('fa-regular', i >= _selectedRating);
        });
    }

    function selectStars(val) {
        _selectedRating = val;
        document.getElementById('selectedRating').value = val;
        resetStars();
    }

    function submitReview(orderId) {
        var rating = _selectedRating;
        if (rating === 0) {
            Swal.fire({ icon: 'warning', title: 'Chưa chọn sao!', text: 'Vui lòng chọn ít nhất 1 sao để đánh giá nhé.', confirmButtonColor: '#EA580C' });
            return;
        }
        var comment = document.getElementById('reviewComment').value;
        fetch('/Order/SubmitReview', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ orderId: orderId, rating: rating, comment: comment })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
            closeReviewModal();
            Swal.fire({ icon: 'success', title: 'Cảm ơn bạn! 🎉', text: 'Đánh giá của bạn đã được ghi nhận.', confirmButtonColor: '#EA580C' });
        })
        .catch(function() {
            Swal.fire({ icon: 'error', title: 'Lỗi!', text: 'Không thể gửi đánh giá. Vui lòng thử lại.', confirmButtonColor: '#EA580C' });
        });
    }
</script>

<script>
    function cancelOrder(orderId) {
        Swal.fire({
            title: 'Hủy đơn hàng?',
            text: "Bạn có chắc chắn muốn hủy đơn hàng này không?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Đồng ý hủy',
            cancelButtonText: 'Đóng'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/Order/CancelOrder/${orderId}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire('Thành công!', data.message, 'success')
                        .then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi!', data.message, 'error');
                    }
                })
                .catch(err => Swal.fire('Lỗi!', 'Không thể thực hiện yêu cầu.', 'error'));
            }
        });
    }
</script>